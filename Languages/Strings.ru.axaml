    <x:String x:Key="TxtInitialScanStart">Начать сканирование</x:String>
    <x:String x:Key="TxtInitialScanClose">Закрыть</x:String>
    <x:String x:Key="TxtInitialScanNoDrives">Диски не обнаружены.</x:String>
    <x:String x:Key="TxtStatusReady">Готово</x:String>
    <x:String x:Key="TxtScanningTitle">Сканирование игр...</x:String>
    <x:String x:Key="TxtScanningDesc">Поиск игр на всех платформах...</x:String>
    <x:String x:Key="TxtSearchGames">Поиск игр...</x:String>
