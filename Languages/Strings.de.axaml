<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <x:String x:Key="TxtSettingsTitle">Einstellungen</x:String>
    <x:String x:Key="TxtSettingsDesc">Anwendungseinstellungen verwalten</x:String>
    <x:String x:Key="TxtAppPrefs">Anwendungseinstellungen</x:String>
    <x:String x:Key="TxtCacheMgmt">Lokaler Cache &amp; Standard-Versionsverwaltung</x:String>
    <x:String x:Key="TxtCacheDesc">Heruntergeladene Komponentenversionen anzeigen und verwalten, Standardversionen für Schnellinstallation und Spielverwaltung festlegen und lokalen Speicherplatz freigeben.</x:String>
    <x:String x:Key="TxtManage">&#xE8B7;  Verwalten</x:String>
    <x:String x:Key="TxtLanguage">Anwendungssprache</x:String>
    <x:String x:Key="TxtLanguageDesc">Benutzeroberflächensprache ändern.</x:String>
    <x:String x:Key="TxtClose">Schließen</x:String>
    <x:String x:Key="TxtGotIt">Verstanden</x:String>
    <x:String x:Key="TxtAppRepoTitle">Anwendungs-Repository</x:String>
    <x:String x:Key="TxtAppRepoDesc">Ziel-GitHub-Repository für Updates und Feedback (Besitzer/RepoName).</x:String>
    <!-- Guide Window -->
    <x:String x:Key="TxtGuideTitle">Leitfaden</x:String>
    <x:String x:Key="TxtGuideHeader">Wie man Optiscaler Client verwendet</x:String>
    <x:String x:Key="TxtGuideHeaderDesc">Einfache Schritte zur Verbesserung Ihrer Spiele</x:String>
    <x:String x:Key="TxtGuideStep1Title">1. Finden Sie Ihre Spiele</x:String>
    <x:String x:Key="TxtGuideStep1Desc">Klicken Sie auf 'Spiele scannen', damit die Anwendung automatisch installierte Spiele von Steam, Epic, GOG oder Xbox findet. Überprüfen Sie die 'Manuell hinzufügen' Schaltfläche, wenn Sie ein Standalone-Spiel haben.</x:String>
    <x:String x:Key="TxtGuideStep2Title">2. Ein Spiel verwalten</x:String>
    <x:String x:Key="TxtGuideStep2Desc">Neben Ihrem Spiel in der Liste klicken Sie auf 'Verwalten'. Ein Fenster öffnet sich, das Ihnen ermöglicht, den OptiScaler-Mod für dieses spezifische Spiel zu installieren oder zu aktualisieren.</x:String>
    <x:String x:Key="TxtGuideStep3Title">3. OptiScaler installieren</x:String>
    <x:String x:Key="TxtGuideStep3Desc">Im Verwaltungsfenster wählen Sie Ihre OptiScaler-Version und Optionen. Verwenden Sie 'Automatische Installation' für eine schnelle Einrichtung. Wenn die automatische Installation fehlschlägt oder die richtige ausführbare Datei (.exe) nicht finden kann, verwenden Sie 'Manuelle Installation', um die ausführbare Datei des Spiels selbst auszuwählen.</x:String>
    <x:String x:Key="TxtGuideStep4Title">4. Das Spiel spielen</x:String>
    <x:String x:Key="TxtGuideStep4Desc">Nach der Installation starten Sie Ihr Spiel normal. Öffnen Sie im Spiel das OptiScaler-Menü mit der 'Insert'-Taste, um Ihre Einstellungen anzupassen!</x:String>

    <!-- MainWindow -->
    <x:String x:Key="TxtAppTitle">Optiscaler Client Next</x:String>
