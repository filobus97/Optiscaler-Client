    <!-- Games View - Scan & Organize -->
    <x:String x:Key="TxtSkipNoDllsTitle">Spiele ohne Upscaling-DLLs überspringen</x:String>
    <x:String x:Key="TxtSkipNoDllsDesc">Spiele ignorieren, die keine erkennbaren DLSS-, FSR- oder XeSS-Bibliotheken haben. Nur mit OptiScaler kompatible Spiele werden hinzugefügt.</x:String>
    <x:String x:Key="TxtRefreshCoversTitle">Nur fehlende Cover aktualisieren</x:String>
    <x:String x:Key="TxtRefreshCoversDesc">Uberspringt den vollstandigen Scan und wiederholt nur das Abrufen von Cover-Bildern fur Spiele, die zuvor nicht gefunden werden konnten. Nutzlich nach dem Einrichten eines SteamGridDB-API-Schluessels.</x:String>
    <x:String x:Key="TxtOrganizeGamesTooltip">Spiele organisieren</x:String>
    <x:String x:Key="TxtOrganizeModeBanner">Organisationsmodus</x:String>
    <x:String x:Key="TxtOrganizeModeReorder">▲▼ neu anordnen</x:String>
    <x:String x:Key="TxtOrganizeModeHideShow">ein-/ausblenden</x:String>
    <x:String x:Key="TxtOrganizeModeDone">Fertig</x:String>
    <x:String x:Key="TxtDragToReorder">Zum Neuanordnen ziehen</x:String>
    <x:String x:Key="TxtMoveUp">Nach oben</x:String>
    <x:String x:Key="TxtMoveDown">Nach unten</x:String>
    <x:String x:Key="TxtHideShowGame">Spiel ein-/ausblenden</x:String>
    <x:String x:Key="TxtHideGame">Ausblenden</x:String>
    <x:String x:Key="TxtShowGame">Einblenden</x:String>
    <x:String x:Key="TxtRefreshingCovers">Fehlende Cover werden aktualisiert...</x:String>
    <x:String x:Key="TxtCoverRefreshDoneFmt">Cover-Aktualisierung abgeschlossen. {0}/{1} fehlende Cover gefunden.</x:String>
    <x:String x:Key="TxtCoverRefreshToastFmt">Cover-Aktualisierung abgeschlossen — {0}/{1} Cover gefunden.</x:String>

    <!-- OptiPatcher -->
    <x:String x:Key="TxtOptiPatcherLbl">OptiPatcher</x:String>
    <x:String x:Key="TxtOptiPatcherTooltip">Ein ASI-Plugin für OptiScaler, das DLSS/DLSS-FG-Eingaben ohne Spoofing in unterstützten Spielen freilegt. Hilft Intel Arc-Nutzern, D3D12-Fehler zu vermeiden, und verhindert Leistungseinbußen oder Abstürze durch Dxgi-Spoofing.</x:String>
    <x:String x:Key="TxtDownloadingOptiPatcher">OptiPatcher wird heruntergeladen...</x:String>
    <x:String x:Key="TxtInstallingOptiPatcher">OptiPatcher wird installiert...</x:String>
    <x:String x:Key="TxtVersionMgmtInfoTitle">Versionsverwaltung</x:String>
    <x:String x:Key="TxtVersionMgmtInfoDesc">OptiScaler-, OptiPatcher-, FSR4 INT8-, Fakenvapi- und NukemFG-Versionen können im Bereich Lokaler Cache &amp; Standard-Versionsverwaltung in den Einstellungen verwaltet werden.</x:String>
    <x:String x:Key="TxtSetDefault">Als Standard</x:String>
    <x:String x:Key="TxtClearDefault">Löschen</x:String>
    <x:String x:Key="TxtDefaultBadge">STANDARD</x:String>
    <x:String x:Key="TxtCurrentDefaultFormat">Aktueller Standard: {0}</x:String>
    <x:String x:Key="TxtNoDefaultSet">Kein Standard festgelegt</x:String>
    <!-- Network / Proxy Settings -->
    <x:String x:Key="TxtNetworkTitle">Netzwerk &amp; Proxy</x:String>
    <x:String x:Key="TxtNetworkDesc">Konfigurieren Sie einen HTTP(S)-Proxy für die GitHub-API und Download-Verbindungen.</x:String>
    <x:String x:Key="TxtNetworkWindowDesc">Konfigurieren Sie einen HTTP(S)- oder SOCKS5-Proxy für die GitHub-API und Download-Verbindungen. Leer lassen, um das Systemproxy zu verwenden.</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxy">Systemproxy verwenden</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxyDesc">Wenn aktiviert, werden die Proxy-Einstellungen des OS und die Umgebungsvariablen HTTP_PROXY / HTTPS_PROXY verwendet. Deaktivieren, um einen benutzerdefinierten Proxy festzulegen.</x:String>
