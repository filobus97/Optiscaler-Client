    <x:String x:Key="TxtBtnEdit">編集</x:String>
    <x:String x:Key="TxtBtnDuplicate">複製</x:String>
    <x:String x:Key="TxtBtnExportIni">.iniをエクスポート</x:String>
    <x:String x:Key="TxtSearchProfiles">プロフィールを検索...</x:String>
