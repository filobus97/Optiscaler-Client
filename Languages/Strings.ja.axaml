    <x:String x:Key="TxtProfSearchResultFormat">{1}件中 {0}件の結果.</x:String>
    <x:String x:Key="TxtProfNotFound">プロフィールが見つかりません.</x:String>
    <x:String x:Key="TxtProfSearchNotFound">一致するプロフィールが見つかりません.</x:String>

    <!-- Profile Editor View -->
    <x:String x:Key="TxtEditorBackBtn">← プロフィール</x:String>
    <x:String x:Key="TxtEditorTitle">プロフィールエディタ</x:String>
    <x:String x:Key="TxtEditorDesc">このプロフィールのOptiScaler設定を構成します</x:String>
    <x:String x:Key="TxtEditorNewTitle">新しいプロフィール</x:String>
    <x:String x:Key="TxtEditorEditTitleFmt">編集: {0}</x:String>
    <x:String x:Key="TxtEditorNameLabel">プロフィール名</x:String>
    <x:String x:Key="TxtEditorNameWatermark">プロフィール名を入力</x:String>
    <x:String x:Key="TxtEditorDescLabel">説明</x:String>
    <x:String x:Key="TxtEditorDescWatermark">説明を入力（任意）</x:String>
    <x:String x:Key="TxtEditorModeLabel">モード</x:String>
    <x:String x:Key="TxtEditorModeEasy">簡単</x:String>
    <x:String x:Key="TxtEditorModeAdvanced">詳細</x:String>
    <x:String x:Key="TxtEditorNavLabel">ナビゲーション</x:String>
    <x:String x:Key="TxtEditorSearchWm">設定を検索...</x:String>
    <x:String x:Key="TxtEditorFooterNote">設定された項目のみOptiScalerのデフォルト値を上書きします</x:String>
    <x:String x:Key="TxtEditorCancel">キャンセル</x:String>
    <x:String x:Key="TxtEditorSave">プロフィールを保存</x:String>

    <!-- Games View - Scan & Organize -->
    <x:String x:Key="TxtSkipNoDllsTitle">アップスケーリングDLLのないゲームをスキップ</x:String>
    <x:String x:Key="TxtSkipNoDllsDesc">DLSS、FSR、またはXeSSライブラリが検出されないゲームを無視します。OptiScalerと互換性のあるゲームのみが追加されます。</x:String>
    <x:String x:Key="TxtRefreshCoversTitle">不足しているカバーのみ更新</x:String>
    <x:String x:Key="TxtRefreshCoversDesc">フルスキャンをスキップし、以前に取得できなかったゲームのカバー画像の再取得のみを試みます。SteamGridDB APIキーを設定した後に役立ちます。</x:String>
    <x:String x:Key="TxtOrganizeGamesTooltip">ゲームを整理</x:String>
    <x:String x:Key="TxtOrganizeModeBanner">整理モード</x:String>
    <x:String x:Key="TxtOrganizeModeReorder">▲▼ 並べ替え</x:String>
    <x:String x:Key="TxtOrganizeModeHideShow">表示/非表示</x:String>
    <x:String x:Key="TxtOrganizeModeDone">完了</x:String>
    <x:String x:Key="TxtDragToReorder">ドラッグして並べ替え</x:String>
    <x:String x:Key="TxtMoveUp">上に移動</x:String>
    <x:String x:Key="TxtMoveDown">下に移動</x:String>
    <x:String x:Key="TxtHideShowGame">ゲームを表示/非表示</x:String>
    <x:String x:Key="TxtHideGame">非表示</x:String>
    <x:String x:Key="TxtShowGame">表示</x:String>
    <x:String x:Key="TxtRefreshingCovers">不足しているカバーを更新中...</x:String>
    <x:String x:Key="TxtCoverRefreshDoneFmt">カバーの更新が完了しました。{0}/{1}件の不足カバーが見つかりました。</x:String>
    <x:String x:Key="TxtCoverRefreshToastFmt">カバーの更新が完了しました — {0}/{1}件のカバーが見つかりました。</x:String>

    <!-- OptiPatcher -->
    <x:String x:Key="TxtOptiPatcherLbl">OptiPatcher</x:String>
    <x:String x:Key="TxtOptiPatcherTooltip">サポートするゲームでスプーフィングなしにDLSS/DLSS-FG入力を公開するOptiScaler用ASIプラグインです。Intel ArcユーザーのD3D12エラーやDxgiスプーフィングによるパフォーマンス低下・クラッシュを防ぎます。</x:String>
    <x:String x:Key="TxtDownloadingOptiPatcher">OptiPatcherをダウンロード中...</x:String>
    <x:String x:Key="TxtInstallingOptiPatcher">OptiPatcherをインストール中...</x:String>
    <x:String x:Key="TxtVersionMgmtInfoTitle">バージョン管理</x:String>
    <x:String x:Key="TxtVersionMgmtInfoDesc">OptiScaler、OptiPatcher、FSR4 INT8、Fakenvapi、NukemFGのバージョンは、設定のローカルキャッシュ &amp; デフォルトバージョン管理セクションから管理できます。</x:String>
    <x:String x:Key="TxtSetDefault">デフォルトに設定</x:String>
    <x:String x:Key="TxtClearDefault">クリア</x:String>
    <x:String x:Key="TxtDefaultBadge">デフォルト</x:String>
    <x:String x:Key="TxtCurrentDefaultFormat">現在のデフォルト: {0}</x:String>
    <x:String x:Key="TxtNoDefaultSet">デフォルト未設定</x:String>
    <!-- Network / Proxy Settings -->
    <x:String x:Key="TxtNetworkTitle">ネットワークとプロキシ</x:String>
    <x:String x:Key="TxtNetworkDesc">GitHub API とダウンロード接続のための HTTP(S) プロキシを設定します。</x:String>
    <x:String x:Key="TxtNetworkWindowDesc">GitHub API とダウンロード接続のための HTTP(S) または SOCKS5 プロキシを設定します。システムプロキシを使用するには空のままにしてください。</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxy">システムプロキシを使用</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxyDesc">有効にすると、OS のプロキシ設定と HTTP_PROXY / HTTPS_PROXY 環境変数が使用されます。カスタムプロキシを設定するには無効にしてください。</x:String>
    <x:String x:Key="TxtNetworkProxyConfig">プロキシ設定</x:String>
    <x:String x:Key="TxtNetworkProxyType">タイプ</x:String>
    <x:String x:Key="TxtNetworkProxyHost">ホスト</x:String>
    <x:String x:Key="TxtNetworkProxyHostPlaceholder">proxy.example.com</x:String>
    <x:String x:Key="TxtNetworkProxyPort">ポート</x:String>
    <x:String x:Key="TxtNetworkProxyPortPlaceholder">3128</x:String>
    <x:String x:Key="TxtNetworkRequiresAuth">プロキシに認証が必要</x:String>
    <x:String x:Key="TxtNetworkCredentials">資格情報</x:String>
    <x:String x:Key="TxtNetworkUsername">ユーザー名</x:String>
    <x:String x:Key="TxtNetworkUsernamePlaceholder">任意</x:String>
    <x:String x:Key="TxtNetworkPassword">パスワード</x:String>
    <x:String x:Key="TxtNetworkPasswordPlaceholder">任意</x:String>
    <x:String x:Key="TxtNetworkTestBtn">接続をテスト</x:String>
    <x:String x:Key="TxtNetworkTestOk">✓ 接続成功</x:String>
    <x:String x:Key="TxtNetworkTestFail">✗ 失敗</x:String>
    <x:String x:Key="TxtNetworkTestTesting">テスト中…</x:String>

    <!-- Welcome popup -->
    <x:String x:Key="TxtWelcomeChangelogTitle">変更履歴</x:String>
    <x:String x:Key="TxtWelcomeChangelogContent">このバージョンの変更点と新機能の完全なリストはGitHubで確認できます。</x:String>
    <x:String x:Key="TxtWelcomeChangelogLink">&#x2197; GitHubで変更履歴を見る</x:String>
    <x:String x:Key="TxtWelcomeGuideTitle">はじめに</x:String>
    <x:String x:Key="TxtWelcomeGuideContent">アプリに慣れるため、または特定の質問を解決するために、ヘルプタブの組み込みガイドを確認することを強くお勧めします。</x:String>
</ResourceDictionary>



