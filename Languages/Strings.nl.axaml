    <x:String x:Key="TxtTipComponent">Componentversies</x:String>
    <x:String x:Key="TxtUpdateNukem">↑  Update NukemFG</x:String>
    <x:String x:Key="TxtTipUpdateNukem">Nieuwe NukemFG versie beschikbaar. Klik om de bijgewerkte DLL te leveren.</x:String>
