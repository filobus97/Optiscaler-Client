    <x:String x:Key="TxtQuickUninstall">🗑️ Snelle verwijdering</x:String>
    <x:String x:Key="TxtInitialScanTitle">Eerste scan</x:String>
    <x:String x:Key="TxtInitialScanDesc">Voordat we je schijven scannen op games, kies je welke stations en bronnen je wilt opnemen. Je kunt dit venster sluiten en later scannen.</x:String>
    <x:String x:Key="TxtScanSetupTitle">Scaninstellingen</x:String>
    <x:String x:Key="TxtScanSetupDesc">Kies welke stations en bronnen je wilt scannen. Je kunt dit venster sluiten en later scannen.</x:String>
    <x:String x:Key="TxtInitialScanDrives">Stations om te scannen</x:String>
    <x:String x:Key="TxtInitialScanSources">Bronnen om te scannen</x:String>
    <x:String x:Key="TxtInitialScanStart">Scan starten</x:String>
    <x:String x:Key="TxtInitialScanClose">Sluiten</x:String>
    <x:String x:Key="TxtInitialScanNoDrives">Geen stations gevonden.</x:String>
    <x:String x:Key="TxtStatusReady">Klaar</x:String>
    <x:String x:Key="TxtScanningTitle">Games scannen...</x:String>
    <x:String x:Key="TxtScanningDesc">Zoeken naar games op alle platforms...</x:String>
    <x:String x:Key="TxtSearchGames">Zoek games...</x:String>
    <x:String x:Key="TxtRemoveGameTip">Verwijder handmatig toegevoegde game</x:String>
    <x:String x:Key="TxtRemoveGameTitle">Verwijder Game</x:String>
    <x:String x:Key="TxtRemoveGameConfirm">Weet u zeker dat u '{0}' uit de lijst wilt verwijderen?</x:String>

    <!-- ManageCacheWindow -->
    <x:String x:Key="TxtManageCacheTitle">Beheer Lokale Versies</x:String>
    <x:String x:Key="TxtLocalVersions">Lokale Versies</x:String>
    <x:String x:Key="TxtManageCacheDesc">Beheer gedownloade OptiScaler cache</x:String>
    <x:String x:Key="TxtDownloadedVersions">Gedownloade OptiScaler Versies:</x:String>
    <x:String x:Key="TxtDeleteIcon">🗑️ Verwijder</x:String>
    <x:String x:Key="TxtNoVersions">Momenteel geen versies gedownload.</x:String>
    <x:String x:Key="TxtToastSuccess">Succes</x:String>
    <x:String x:Key="TxtConfirmDelTitle">Bevestig Verwijdering</x:String>
    <x:String x:Key="TxtCustomVersions">Aangepaste OptiScaler-versies</x:String>
    <x:String x:Key="TxtImportArchive">Archief importeren</x:String>
    <x:String x:Key="TxtNoCustomVersions">Geen aangepaste versies geïmporteerd.</x:String>
    <x:String x:Key="TxtCustomVersionWarning">⚠ Importeer aangepaste OptiScaler-builds als 7z-, zip- of rar-archieven. Installatie/deïnstallatie kan mislukken als het archief bestanden bevat die niet door de app gevolgd kunnen worden. Voeg alleen de OptiScaler-releasebestanden toe.</x:String>
    <x:String x:Key="TxtImporting">Importeren...</x:String>
    <x:String x:Key="TxtConfirmDelMsg">Weet u zeker dat u deze versie wilt verwijderen?</x:String>
    <x:String x:Key="TxtCancel">Annuleren</x:String>
    <x:String x:Key="TxtDeletePlain">Verwijder</x:String>
    <x:String x:Key="TxtConfirmDelFormat">Weet u zeker dat u OptiScaler v{0} uit lokale opslag wilt verwijderen?</x:String>
    <x:String x:Key="TxtDeletedSuccessFormat">OptiScaler v{0} succesvol verwijderd.</x:String>
    <x:String x:Key="TxtFailedDeleteFormat">Kan versie niet verwijderen: {0}</x:String>
    <x:String x:Key="TxtError">Fout</x:String>
    <x:String x:Key="TxtCurrentSelection">Huidige selectie</x:String>
    <x:String x:Key="TxtVersionStored">1 versie lokaal opgeslagen.</x:String>
