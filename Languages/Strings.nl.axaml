    <x:String x:Key="TxtCoverRefreshToastFmt">Omslagvernieuwing voltooid — {0}/{1} omslagen gevonden.</x:String>

    <!-- OptiPatcher -->
    <x:String x:Key="TxtOptiPatcherLbl">OptiPatcher</x:String>
    <x:String x:Key="TxtOptiPatcherTooltip">Een ASI-plugin voor OptiScaler die DLSS/DLSS-FG-invoer blootlegt zonder spoofing in ondersteunde spellen. Helpt Intel Arc-gebruikers D3D12-fouten te vermijden en voorkomt prestatieproblemen of crashes door Dxgi-spoofing.</x:String>
    <x:String x:Key="TxtDownloadingOptiPatcher">OptiPatcher downloaden...</x:String>
    <x:String x:Key="TxtInstallingOptiPatcher">OptiPatcher installeren...</x:String>
    <x:String x:Key="TxtVersionMgmtInfoTitle">Versiebeheer</x:String>
    <x:String x:Key="TxtVersionMgmtInfoDesc">OptiScaler, OptiPatcher, FSR4 INT8, Fakenvapi en NukemFG versies kunnen worden beheerd vanuit het gedeelte Lokale cache &amp; Standaard versiebeheer in Instellingen.</x:String>
    <x:String x:Key="TxtSetDefault">Als standaard instellen</x:String>
    <x:String x:Key="TxtClearDefault">Wissen</x:String>
    <x:String x:Key="TxtDefaultBadge">STANDAARD</x:String>
    <x:String x:Key="TxtCurrentDefaultFormat">Huidige standaard: {0}</x:String>
    <x:String x:Key="TxtNoDefaultSet">Geen standaard ingesteld</x:String>
    <!-- Network / Proxy Settings -->
    <x:String x:Key="TxtNetworkTitle">Netwerk &amp; Proxy</x:String>
    <x:String x:Key="TxtNetworkDesc">Configureer een HTTP(S)-proxy voor de GitHub API en downloadverbindingen.</x:String>
    <x:String x:Key="TxtNetworkWindowDesc">Configureer een HTTP(S)- of SOCKS5-proxy voor de GitHub API en downloadverbindingen. Laat leeg om het systeemplug-in te gebruiken.</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxy">Systeemproxy gebruiken</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxyDesc">Wanneer ingeschakeld, worden de OS-proxyinstellingen en de omgevingsvariabelen HTTP_PROXY / HTTPS_PROXY gebruikt. Schakel uit om een aangepaste proxy in te stellen.</x:String>
