    <!-- ManageGameWindow -->
    <x:String x:Key="TxtManageGameWindow">Beheer Game</x:String>
    <x:String x:Key="TxtOpenFolder">📂  Open Map</x:String>
    <x:String x:Key="TxtOptiStatus">OptiScaler Status</x:String>
    <x:String x:Key="TxtDetectedComponents">Gedetecteerde Componenten</x:String>
    <x:String x:Key="TxtConfirmUninstallTitle">Bevestig Deïnstallatie</x:String>
    <x:String x:Key="TxtConfirmUninstallMsg">Weet u zeker dat u OptiScaler wilt deïnstalleren?&#x0a;Alleen geback-upde originele bestanden worden hersteld.</x:String>
    <x:String x:Key="TxtUninstall">✕ Deïnstalleer</x:String>
    <x:String x:Key="TxtFolderCleanup">🗁 Map opschonen</x:String>
    <x:String x:Key="TxtFolderCleanupTitle">Map geforceerd opschonen</x:String>
    <x:String x:Key="TxtFolderCleanupMsg">Alle bekende OptiScaler-bestanden worden geforceerd verwijderd uit de installatiemap van het spel.&#x0a;&#x0a;Gebruik dit wanneer een vorige OptiScaler-installatie in een beschadigde of onvolledige staat is achtergelaten, of wanneer u wilt terugkeren naar een schone basis vóór het opnieuw installeren.</x:String>
    <x:String x:Key="TxtFolderCleanupSensitiveHeader">&#x26A0;&#xFE0F; Gevoelige bestanden — kunnen ook bij het spel horen</x:String>
    <x:String x:Key="TxtFolderCleanupSensitiveNote">De onderstaande bestanden kunnen native spelbestanden zijn. Ze verwijderen kan het spel beschadigen. Het wordt sterk aanbevolen om de bestandsverificatie van uw launcher (bijv. Steam → Integriteit van spelbestanden verifiëren) daarna uit te voeren. Selecteer alleen de bestanden die u wilt verwijderen:</x:String>
    <x:String x:Key="TxtFolderCleanupSuccess">Map opschonen voltooid.</x:String>
    <x:String x:Key="TxtFolderCleanupFail">Map opschonen mislukt: {0}</x:String>
    <x:String x:Key="TxtCorruptInstallTitle">Beschadigde installatie gedetecteerd</x:String>
    <x:String x:Key="TxtCorruptInstallMsg">OptiScaler-bestanden zijn gevonden in de map van dit spel, maar het spel is niet gemarkeerd als geïnstalleerd. Dit betekent meestal dat een eerdere installatie niet correct is verwijderd.&#x0a;&#x0a;Het wordt sterk aanbevolen de map op te schonen vóór het installeren om conflicten te vermijden. U kunt nu opschonen, doorgaan zonder opschonen, of de installatie annuleren.</x:String>
    <x:String x:Key="TxtCorruptInstallClean">🗁 Opschonen en installeren</x:String>
    <x:String x:Key="TxtCorruptInstallContinue">Toch doorgaan</x:String>
    <x:String x:Key="TxtVersionLbl">Versie:</x:String>
    <x:String x:Key="TxtInjectionLbl">Injectie:</x:String>
    <x:String x:Key="TxtInstallOpti">✦ Automatische installatie</x:String>
    <x:String x:Key="TxtBtnManualInstall">✦ Handmatige Install</x:String>
    <x:String x:Key="TxtUpdateOpti">↑ Auto Update / Herinstalleer</x:String>
    <x:String x:Key="TxtUpdateOptiManual">↑ Handmatige Update / Herinstalleer</x:String>
    <x:String x:Key="TxtFakenvapiTip">Vereist voor AMD/Intel GPU's om DLSS FG in te schakelen met Nukem mod</x:String>
    <x:String x:Key="TxtNukemTip">Nukem's DLSSG-to-FSR3 mod voor Frame Generation</x:String>
    <x:String x:Key="TxtFakenvapiHelpTip">Misleidt de game om een NVIDIA grafische kaart te detecteren, waardoor u hardwarebeperkingen kunt omzeilen en DLSS technologieën kunt inschakelen op AMD of Intel GPU's.</x:String>
    <x:String x:Key="TxtNukemHelpTip">Een mod van Nukem die native DLSS Frame Generation vervangt door AMD FSR 3 Frame Generation, waardoor frame generation wordt ingeschakeld op elke compatibele GPU.</x:String>

    <x:String x:Key="TxtTooltipOptiScalerVersion">Selecteer de specifieke versie van OptiScaler die u voor deze game wilt installeren.</x:String>
    <x:String x:Key="TxtTooltipInjectionMethod">Bepaalt hoe OptiScaler wordt geladen. Gebruikelijke keuzes zijn dxgi.dll of version.dll, afhankelijk van de compatibiliteit van de game.</x:String>
    <x:String x:Key="TxtTooltipFsr4Int8">Injecteert de FSR 4 INT8 mod DLL. Hiermee kunnen niet-RDNA 4 GPU's FSR 4-functies gebruiken. Selecteer 'Geen' als u een RX 9000-serie (RDNA 4) GPU hebt.</x:String>

    <x:String x:Key="TxtOptiInstalled">OptiScaler Geïnstalleerd</x:String>
    <x:String x:Key="TxtOptiNotInstalled">Niet Geïnstalleerd</x:String>
    <x:String x:Key="TxtNoOptiDetected">Geen versie gedetecteerd</x:String>
    <x:String x:Key="TxtOptiLatest"> (Laatste)</x:String>
    <x:String x:Key="TxtInstallingFormat">OptiScaler v{0} downloaden... {1}%</x:String>
    <x:String x:Key="TxtExtractingFormat">v{0} uitpakken en installeren...</x:String>
    <x:String x:Key="TxtInstallSuccessFormat">{0} succesvol geïnstalleerd!</x:String>
    <x:String x:Key="TxtDownloadErrorPrefix">Kan OptiScaler niet downloaden: {0}</x:String>
    <x:String x:Key="TxtOptiUninstallSuccess">OptiScaler succesvol gedeïnstalleerd.</x:String>
    <x:String x:Key="TxtOptiUninstallFail">Deïnstallatie mislukt: {0}</x:String>
    <x:String x:Key="TxtInstallSuccessTitle">Installatie Succesvol</x:String>

    <!-- ManualDownloadDialog -->
    <x:String x:Key="TxtManualTitle">Handmatig Bestand Vereist</x:String>
    <x:String x:Key="TxtDownloadFrom">Download van: </x:String>
    <x:String x:Key="TxtReqFileLbl">Vereist bestand: </x:String>
    <x:String x:Key="TxtBrowse">Bladeren…</x:String>
    <x:String x:Key="TxtConfirmBtn">✓ Bevestig</x:String>
    
    <x:String x:Key="TxtManualUpdateTitle">🔄 Handmatige Update Beschikbaar</x:String>
    <x:String x:Key="TxtManualUpdateInst">Een nieuwe versie van NukemFG is beschikbaar op Nexus Mods.&#x0a;Download het bijgewerkte bestand via de link hieronder en selecteer de DLL (of ZIP):</x:String>
    <x:String x:Key="TxtManualUpdateHint">Klik op 'Bladeren' om de DLL, ZIP of map met het bijgewerkte bestand te selecteren.</x:String>
    <x:String x:Key="TxtBtnUpdate">Bijwerken</x:String>
    <x:String x:Key="TxtBtnLater">Later</x:String>

    <!-- Help View Strings -->
    <x:String x:Key="TxtAboutTitle">Help</x:String>
    <x:String x:Key="TxtFeedbackTitle">Feedback</x:String>
    <x:String x:Key="TxtFeedbackDesc">Als u functies wilt aanvragen of bugs wilt rapporteren, open dan een issue in de GitHub repository.</x:String>
    <x:String x:Key="TxtBuildDateLbl">Laatste Build Datum</x:String>
    <x:String x:Key="TxtCheckUpdatesBtn">Controleer updates</x:String>
    <x:String x:Key="TxtGithubBtn">GitHub Repository</x:String>

    <x:String x:Key="TxtManualReqTitle">⚠️ Handmatig Bestand Vereist</x:String>
    <x:String x:Key="TxtManualReqInst">NukemFG kan niet automatisch worden gedownload.&#x0a;Download het bestand van Nexus Mods en selecteer de DLL (of ZIP) hieronder:</x:String>
    <x:String x:Key="TxtManualReqHint">Klik op 'Bladeren' om direct de DLL, ZIP of uitgepakte map te selecteren.</x:String>
    <x:String x:Key="TxtBtnConfirm">Bevestig</x:String>
    <x:String x:Key="TxtBtnSkip">Overslaan</x:String>

