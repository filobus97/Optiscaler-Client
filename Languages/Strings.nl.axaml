    <x:String x:Key="TxtNoGpu">⚠️ Geen GPU gedetecteerd</x:String>
    <x:String x:Key="TxtNoGpuTip">Er is geen GPU gedetecteerd op dit systeem</x:String>
    <x:String x:Key="TxtGpuFail">⚠️ GPU detectie mislukt</x:String>
    <x:String x:Key="TxtGpuFailTipFormat">GPU detectie fout: {0}</x:String>
    <x:String x:Key="TxtAutoScan">Auto-Scan bij Opstarten</x:String>
    <x:String x:Key="TxtAutoScanDesc">Scan automatisch voor games als de lijst leeg is bij opstarten.</x:String>
    <x:String x:Key="TxtAnimations">Activeer animaties</x:String>
    <x:String x:Key="TxtAnimationsDesc">Activeer soepele overgangen en animaties in de hele interface</x:String>
    <x:String x:Key="TxtBetaVersions">Voorkeur voor laatste beta als standaard</x:String>
    <x:String x:Key="TxtBetaVersionsDesc">Wanneer ingeschakeld, selecteert automatisch de laatste beta versie in plaats van de stabiele release.</x:String>
    <x:String x:Key="TxtBetaIncludesComponents">Deze versie bevat al Fakenvapi en NukemFG</x:String>
    <x:String x:Key="TxtFsr4Int8DefaultTitle">Standaard FSR4 INT8</x:String>
    <x:String x:Key="TxtFsr4Int8DefaultDesc">Standaard FSR4 INT8-modversie die vooraf wordt geselecteerd bij het openen van een spel. RDNA 4-GPU's (RX 9000-serie) gebruiken automatisch Geen.</x:String>
    <x:String x:Key="TxtDefaultGpuTitle">Standaard GPU</x:String>
    <x:String x:Key="TxtDefaultGpuDesc">Gebruikt voor standaardwaarden en GPU-specifieke begeleiding.</x:String>
    <x:String x:Key="TxtDefaultOptiVersionTitle">Standaard OptiScaler-versie</x:String>
    <x:String x:Key="TxtDefaultOptiVersionDesc">Vooraf geselecteerde versie bij het openen van Beheren of Snel installeren. 'Auto' kiest de nieuwste aanbevolen versie.</x:String>
    <x:String x:Key="TxtDefaultVersionsTitle">Standaardversies</x:String>
    <x:String x:Key="TxtDefaultVersionsDesc">Standaard componentversies beheren voor spelbeheer en Snel installeren</x:String>
    <x:String x:Key="TxtManageDefaultVersions">Standaardversies beheren</x:String>
    <x:String x:Key="TxtManageDefaultVersionsDesc">Configureer welke componentversies vooraf geselecteerd worden bij het openen van het spelbeheervenster of bij Snel installeren.</x:String>
    <x:String x:Key="TxtOptiPatcherDefaultTitle">Standaard OptiPatcher-versie</x:String>
    <x:String x:Key="TxtOptiPatcherDefaultDesc">Vooraf geselecteerde OptiPatcher-versie bij het openen van Beheren of Snel installeren. Selecteer Geen om installatie over te slaan.</x:String>
    <x:String x:Key="TxtOptiPatcherSupportLinkText">Zie lijst van ondersteunde spellen</x:String>
    <x:String x:Key="TxtClearAppCacheTitle">Applicatiecache wissen</x:String>
    <x:String x:Key="TxtClearAppCacheDesc">Verwijdert gescande spellen, omslagafbeeldingen en gecachte versiegegevens. De app scant opnieuw bij de volgende start.</x:String>
    <x:String x:Key="TxtClearCacheBtn">Cache wissen</x:String>
    <x:String x:Key="TxtClearAppCacheDialogMsg">Waarschuwing: Dit zal alle gescande spellen, omslagafbeeldingen en gecachte OptiScaler-versiegegevens permanent verwijderen.&#x0a;&#x0a;De applicatie sluit na het wissen. Bij de volgende start wordt de bibliotheek opnieuw gescand en versie-informatie opnieuw gedownload.</x:String>

    <!-- Scan Sources -->
    <x:String x:Key="TxtManageScanSources">Scanbronnen beheren</x:String>
    <x:String x:Key="TxtManageScanSourcesDesc">Configureer welke platforms en mappen te scannen voor games</x:String>
    <x:String x:Key="TxtDefaultSources">Standaardbronnen</x:String>
    <x:String x:Key="TxtCustomFolders">Aangepaste mappen</x:String>
    <x:String x:Key="TxtAddFolder">+ Map toevoegen</x:String>
    <x:String x:Key="TxtNoCustomFolders">Nog geen aangepaste mappen toegevoegd.</x:String>
    <x:String x:Key="TxtFilterOptions">Filteropties</x:String>
    <x:String x:Key="TxtFilterShowAllTitle">Alle games scannen</x:String>
    <x:String x:Key="TxtFilterShowAllDesc">Alle geïnstalleerde games van alle ingeschakelde bronnen detecteren en weergeven.</x:String>
    <x:String x:Key="TxtFilterHideTitle">Alles scannen, games zonder upscalers verbergen</x:String>
    <x:String x:Key="TxtFilterHideDesc">Alles scannen, maar games zonder detecteerbare DLSS, FSR of XeSS automatisch verbergen. Verborgen games blijven in de lijst en kunnen worden weergegeven vanuit de Organiseer-modus.</x:String>
    <x:String x:Key="TxtFilterSkipTitle">Games zonder upscalers overslaan</x:String>
    <x:String x:Key="TxtFilterSkipDesc">Alleen games opnemen waarbij DLSS-, FSR- of XeSS-DLL's zijn gedetecteerd.</x:String>
    <x:String x:Key="TxtFilterSkipWarning">Sommige games ondersteunen upscalers maar tonen hun DLL's niet op een detecteerbaar pad. Die games verschijnen niet in de lijst.</x:String>
    <x:String x:Key="TxtShowNonGameApps">Spellen zonder upscalers weergeven (DLSS/FSR/XeSS)</x:String>
    <x:String x:Key="TxtRemove">Verwijderen</x:String>
    <x:String x:Key="TxtSave">Opslaan</x:String>
    <x:String x:Key="TxtScanSources">Scanbronnen</x:String>
    <x:String x:Key="TxtScanSourcesDesc">Beheer platforms en aangepaste mappen om te scannen</x:String>

    <!-- App Update -->
    <x:String x:Key="TxtUpdateAvailableTitle">Update Beschikbaar</x:String>
    <x:String x:Key="TxtUpdateAvailableMsg">Een nieuwe versie van Optiscaler Client is beschikbaar (v{0}).&#x0a;Wilt u deze nu downloaden en installeren?</x:String>
    <x:String x:Key="TxtUpdatingApp">App updaten...</x:String>
    <x:String x:Key="TxtUpdateReady">Update Klaar</x:String>
    <x:String x:Key="TxtUpdateReadyMsg">De update is gedownload. De applicatie zal nu herstarten om de installatie te voltooien.</x:String>
    <x:String x:Key="TxtUpdateError">Update Fout</x:String>
    <x:String x:Key="TxtNoUpdateFound">De applicatie is al up-to-date.</x:String>
    <x:String x:Key="TxtUpdateCheckError">Er was een probleem bij het controleren op updates. Probeer het later opnieuw.</x:String>

    <x:String x:Key="TxtBtnBulkInstall">⚡  Bulk Installatie</x:String>

