    <!-- ComponentInfoWindow -->
    <x:String x:Key="TxtComponentTitle">Componentversies</x:String>
    <x:String x:Key="TxtComponentDesc">Geïnstalleerde versies van OptiScaler toolkit</x:String>
    <x:String x:Key="TxtBtnGuide">📖 Gids</x:String>
    <x:String x:Key="TxtUpdateAvail">Update beschikbaar</x:String>
