    <!-- Help Window -->
    <x:String x:Key="TxtHelpTitle">Help</x:String>
    <x:String x:Key="TxtHelpCategoryGuides">Guides</x:String>
    <x:String x:Key="TxtHelpPageAbout">About &amp; Feedback</x:String>
    <x:String x:Key="TxtHelpPageGettingStarted">Getting Started</x:String>
    <x:String x:Key="TxtHelpPageFeatures">Features</x:String>
    <x:String x:Key="TxtHelpPageMainWindow">Main Window</x:String>
    <x:String x:Key="TxtHelpPageGameManagement">Game Management</x:String>
    <x:String x:Key="TxtHelpPageProfiles">Profile System</x:String>
    <x:String x:Key="TxtHelpPageSettings">Settings &amp; Configuration</x:String>
    <x:String x:Key="TxtHelpPageBulkOperations">Bulk Operations</x:String>
    <x:String x:Key="TxtHelpPageTroubleshooting">FAQ &amp; Troubleshooting</x:String>
    <x:String x:Key="TxtHelpDisclaimerTitle">Disclaimer ⚠️</x:String>
    <x:String x:Key="TxtHelpDisclaimerContent">This is not an official OptiScaler project. I am not affiliated with the OptiScaler team. This is a personal project developed without any commercial purpose. Anyone is free to try and use this software at their own risk.&#x0a;&#x0a;Credits: A special thanks to the OptiScaler team; this tool is only possible thanks to their incredible work on the original mod.</x:String>
    <x:String x:Key="TxtHelpSystemTitle">System</x:String>
    <x:String x:Key="TxtHelpLicenseTitle">License &amp; Copyright</x:String>
    <x:String x:Key="TxtHelpLicenseContent">Copyright 2026 Agustinm28&#x0a;&#x0a;Licensed under GPL-3.0-or-later. This is free software: you are free to change and redistribute it under certain conditions. See the LICENSE file for details.&#x0a;&#x0a;Third-party components (OptiScaler, Fakenvapi, NukemFG, FSR4 INT8) are subject to their respective licenses.</x:String>


    <!-- Help - Getting Started -->
    <x:String x:Key="TxtHelpGSWelcomeTitle">Welcome to OptiScaler Client</x:String>
    <x:String x:Key="TxtHelpGSWelcomeContent">OptiScaler Client is a modern, high-performance desktop utility designed to simplify the installation, management, and update of the OptiScaler mod across your entire game library.</x:String>
    <x:String x:Key="TxtHelpGSIntroContent">This guide is designed to help you navigate and understand the program's core features. It serves as a comprehensive help center for any questions you may have, and includes step-by-step tutorials to get you started.</x:String>
    <x:String x:Key="TxtHelpGSQuickStart">Quick Start</x:String>
    <x:String x:Key="TxtHelpGSStep1Label">Step 1: Scan for Games</x:String>
    <x:String x:Key="TxtHelpGSStep1Text">Click the 'Scan' button in the main window to automatically detect games on your system from Steam, Epic Games, and other platforms.</x:String>
    <x:String x:Key="TxtHelpGSStep2Label">Step 2: Select a Game</x:String>
    <x:String x:Key="TxtHelpGSStep2Text">Browse your game library and click 'Manage' on any game you want to enhance with upscaling technology.</x:String>
    <x:String x:Key="TxtHelpGSStep3Label">Step 3: Configure &amp; Install</x:String>
    <x:String x:Key="TxtHelpGSStep3Text">Before installing, feel free to adjust the options to your liking. Once you're ready, click 'Auto Install' in the game management window to apply your custom settings automatically.</x:String>
    <x:String x:Key="TxtHelpGSStep4Label">Step 4: Enjoy!</x:String>
    <x:String x:Key="TxtHelpGSStep4Text">Everything is ready! You can now launch the game directly and enjoy.</x:String>


    <!-- Help - Features -->
    <x:String x:Key="TxtHelpFeatOffersTitle">What OptiScaler Client Offers</x:String>
    <x:String x:Key="TxtHelpFeatOffersContent">OptiScaler Client provides comprehensive management for Optiscaler.</x:String>
    <x:String x:Key="TxtHelpFeatDetectionLabel">Automatic Game Detection</x:String>
    <x:String x:Key="TxtHelpFeatDetectionText">Scans Steam, Epic Games, GOG, and other platforms to find your installed games.</x:String>
    <x:String x:Key="TxtHelpFeatInstallLabel">One-Click Installation</x:String>
    <x:String x:Key="TxtHelpFeatInstallText">Quick install feature deploys OptiScaler with optimal settings in seconds.</x:String>
    <x:String x:Key="TxtHelpFeatProfilesLabel">Profile Management</x:String>
    <x:String x:Key="TxtHelpFeatProfilesText">Create and manage custom profiles for different games and scenarios.</x:String>
    <x:String x:Key="TxtHelpFeatBulkLabel">Bulk Operations</x:String>
    <x:String x:Key="TxtHelpFeatBulkText">Install or update OptiScaler across multiple games simultaneously.</x:String>
    <x:String x:Key="TxtHelpFeatVersionLabel">Version Control</x:String>
    <x:String x:Key="TxtHelpFeatVersionText">Easily switch between different versions of OptiScaler, Fakenvapi, and NukemFG.</x:String>
    <x:String x:Key="TxtHelpFeatMetadataLabel">Metadata Integration</x:String>
    <x:String x:Key="TxtHelpFeatMetadataText">Automatic cover art and game information from SteamGridDB.</x:String>


    <!-- Help - Main Window + Game Management -->
    <x:String x:Key="TxtHelpMWTitle">Game Library Overview</x:String>
    <x:String x:Key="TxtHelpMWContent">The main window is your central hub for managing all your games. Here you can view your entire game library, scan for new games, and access game management features.</x:String>
    <x:String x:Key="TxtHelpMWGameListLabel">Game List 🎮</x:String>
    <x:String x:Key="TxtHelpMWGameListText">Displays all detected games with cover art, title, and installation status.</x:String>
    <x:String x:Key="TxtHelpMWManageBtnLabel">Manage Button ⚙️</x:String>
    <x:String x:Key="TxtHelpMWManageBtnText">Opens the Game Management Window for the selected game, where you can install, configure, and manage OptiScaler.</x:String>
    <x:String x:Key="TxtHelpMWQuickInstallLabel">Quick Install Button ✦</x:String>
    <x:String x:Key="TxtHelpMWQuickInstallText">Quickly install OptiScaler with optimal settings for the selected game.</x:String>
    <x:String x:Key="TxtHelpMWScanLabel">Scan Button 🔍</x:String>
    <x:String x:Key="TxtHelpMWScanText">Automatically detects games from Steam, Epic Games, GOG, EA, Ubisoft, Xbox, and Battle.net. Here you can select which sources you want to scan and even which discs.</x:String>
    <x:String x:Key="TxtHelpMWAddManualLabel">Add Manual Button ➕</x:String>
    <x:String x:Key="TxtHelpMWAddManualText">Allows you to manually add games that weren't automatically detected. Useful for standalone games or custom installations.</x:String>
    <x:String x:Key="TxtHelpMWBulkLabel">Bulk Install ⚡</x:String>
    <x:String x:Key="TxtHelpMWBulkText">Open the bulk installation window, allowing you to install OptiScaler on multiple games at once.</x:String>
    <x:String x:Key="TxtHelpMWSearchLabel">Search &amp; Filter 🔍</x:String>
    <x:String x:Key="TxtHelpMWSearchText">Quickly find games using the search bar.</x:String>
    <x:String x:Key="TxtHelpMWViewLabel">Grid &amp; List mode buttons 📊</x:String>
    <x:String x:Key="TxtHelpMWViewText">Switch between grid and list view modes to organize your game library as you prefer.</x:String>
    <x:String x:Key="TxtHelpMWOrganizeLabel">Organize games ✏️</x:String>
    <x:String x:Key="TxtHelpMWOrganizeText">In this mode you can reorder and hide/show the games in the game list to your liking.</x:String>
    <x:String x:Key="TxtHelpGMTitle">Managing Individual Games</x:String>
    <x:String x:Key="TxtHelpGMContent">The Game Management Window provides complete control over OptiScaler installation and configuration for a specific game.</x:String>
    <x:String x:Key="TxtHelpGMInfoLabel">Game Information 🎮</x:String>
    <x:String x:Key="TxtHelpGMInfoText">View game details including title, executable path, platform, and current OptiScaler installation status.</x:String>
    <x:String x:Key="TxtHelpGMFolderLabel">Open folder 📁</x:String>
    <x:String x:Key="TxtHelpGMFolderText">Open the game's installation folder in File Explorer.</x:String>
    <x:String x:Key="TxtHelpGMCoverLabel">Edit cover and game name 🎨</x:String>
    <x:String x:Key="TxtHelpGMCoverText">Edit the game's cover image and name.</x:String>
    <x:String x:Key="TxtHelpGMAutoInstallLabel">Auto Install ✦</x:String>
    <x:String x:Key="TxtHelpGMAutoInstallText">It attempts to automatically find the game's executable to install OptiScaler, using an algorithm that considers different scenarios and makes it quite robust, but it's not perfect.</x:String>
    <x:String x:Key="TxtHelpGMManualInstallLabel">Manual Install ✦</x:String>
    <x:String x:Key="TxtHelpGMManualInstallText">Allows you to manually select the game's executable file to install OptiScaler. It is recommended to use this option if the automated installation fails to find the executable.</x:String>
    <x:String x:Key="TxtHelpGMUninstallLabel">Uninstall 🗑️</x:String>
    <x:String x:Key="TxtHelpGMUninstallText">Completely remove OptiScaler from the game, restoring original files and configurations from backup.</x:String>
    <x:String x:Key="TxtHelpGMProfileLabel">Profile Selection 🎯</x:String>
    <x:String x:Key="TxtHelpGMProfileText">Choose from pre-configured Optiscaler profiles or create custom profiles tailored to specific games or performance needs.</x:String>
    <x:String x:Key="TxtHelpGMVersionLabel">OptiScaler Version 📦</x:String>
    <x:String x:Key="TxtHelpGMVersionText">Select which version of OptiScaler to install. You can switch between stable releases and beta builds.</x:String>
    <x:String x:Key="TxtHelpGMFakeNvapiLabel">Fakenvapi &amp; NukemFG 📦</x:String>
    <x:String x:Key="TxtHelpGMFakeNvapiText">Optional components that enhance compatibility with certain games. These fields are not required for beta versions of optiscaler that already include these files.</x:String>
    <x:String x:Key="TxtHelpGMInjectionLabel">Injection method 🚀</x:String>
    <x:String x:Key="TxtHelpGMInjectionText">Choose how OptiScaler injects into the game process. For most cases, the default option (dxgi.dll) is sufficient, but if optiscaler is not detected correctly, feel free to try others.</x:String>
    <x:String x:Key="TxtHelpGMFsr4Label">FSR 4 INT8 ⚡</x:String>
    <x:String x:Key="TxtHelpGMFsr4Text">Selector that allows injecting the INT 8 version of FSR 4 for non RDNA 4 GPUs.</x:String>


    <!-- Help - Profiles / Settings / Bulk / FAQ -->
    <x:String x:Key="TxtHelpProfTitle">Creating and Managing Profiles</x:String>
    <x:String x:Key="TxtHelpProfContent">Profiles allow you to save and manage your OptiScaler configurations (.ini files) so you can easily deploy them into new installations. This is the most efficient way to maintain consistent settings or apply specialized tweaks across your game library.</x:String>
    <x:String x:Key="TxtHelpProfMgmtLabel">Profile Management Window 📎</x:String>
    <x:String x:Key="TxtHelpProfMgmtText">Accessible from the sidebar, this section allows you to manage current profiles, as well as search, create, duplicate, edit, or delete them.</x:String>
    <x:String x:Key="TxtHelpProfEditorLabel">Profile Editor 📝</x:String>
    <x:String x:Key="TxtHelpProfEditorText">Configure all OptiScaler (.ini) settings including upscaling method, quality presets, DLL options, and advanced parameters. The sections that can be seen in that window are:</x:String>
    <x:String x:Key="TxtHelpSetTitle">Application Settings</x:String>
    <x:String x:Key="TxtHelpSetContent">Configure OptiScaler Client behavior, scan sources, metadata services, and advanced options.</x:String>
    <x:String x:Key="TxtHelpSetCacheLabel">Local Cache Management</x:String>
    <x:String x:Key="TxtHelpSetCacheText">Allows you to view and delete cached versions of OptiScaler and FSR INT8.</x:String>
    <x:String x:Key="TxtHelpSetProfileLabel">Profile Management</x:String>
    <x:String x:Key="TxtHelpSetProfileText">It allows you to manage different profiles. See the 'Profile System' page for more information.</x:String>
    <x:String x:Key="TxtHelpSetScanLabel">Scan Sources</x:String>
    <x:String x:Key="TxtHelpSetScanText">Allows you to manage which sources are scanned when clicking 'Scan', including platforms like Steam and Epic, as well as custom folders and other locations.</x:String>
    <x:String x:Key="TxtHelpSetFsr4Label">FSR INT8 Default</x:String>
    <x:String x:Key="TxtHelpSetFsr4Text">Allows you to select the default FSR INT8 version for the injection section when managing a game or using Quick Install. It is recommended to set this to 'None' for users with AMD 9000-series graphics cards.</x:String>
    <x:String x:Key="TxtHelpSetGpuLabel">Default GPU Selection</x:String>
    <x:String x:Key="TxtHelpSetGpuText">Choose which GPU to use when multiple GPUs are detected in your system.</x:String>
    <x:String x:Key="TxtHelpSetAutoscanLabel">Auto scan on startup</x:String>
    <x:String x:Key="TxtHelpSetAutoscanText">Automatically scan for games when the application starts.</x:String>
    <x:String x:Key="TxtHelpSetBetaLabel">Prefer latest beta as default</x:String>
    <x:String x:Key="TxtHelpSetBetaText">When enabled, OptiScaler Client will prefer to download and use the latest beta versions of components when available.</x:String>
    <x:String x:Key="TxtHelpSetAnimLabel">Enable animations</x:String>
    <x:String x:Key="TxtHelpSetAnimText">When enabled, OptiScaler Client will show animations and transitions for a more polished user experience.</x:String>
    <x:String x:Key="TxtHelpSetSteamGridLabel">SteamGridDB API Key</x:String>
    <x:String x:Key="TxtHelpSetSteamGridText">Used to improve cover art fetching when they cannot be retrieved by default. This parameter is entirely optional.</x:String>
    <x:String x:Key="TxtHelpBulkTitle">Managing Multiple Games</x:String>
    <x:String x:Key="TxtHelpBulkContent">The Bulk Install Window allows you to install or update OptiScaler across multiple games simultaneously, saving time and ensuring consistency.</x:String>
    <x:String x:Key="TxtHelpBulkGameSelLabel">Game Selection</x:String>
    <x:String x:Key="TxtHelpBulkGameSelText">Choose which games to include in the bulk operation. Select all or manually pick individual games.</x:String>
    <x:String x:Key="TxtHelpBulkConfigLabel">Unified Configuration</x:String>
    <x:String x:Key="TxtHelpBulkConfigText">Apply the same profile, OptiScaler version, and settings to all selected games at once.</x:String>
    <x:String x:Key="TxtHelpBulkProgressLabel">Progress Tracking</x:String>
    <x:String x:Key="TxtHelpBulkProgressText">Monitor installation progress for each game. View success/failure status and detailed logs for troubleshooting.</x:String>
    <x:String x:Key="TxtHelpBulkErrorLabel">Error Handling</x:String>
    <x:String x:Key="TxtHelpBulkErrorText">Continue processing remaining games even if some installations fail. Review errors after completion.</x:String>
    <x:String x:Key="TxtHelpFaqTitle">Common Issues</x:String>
    <x:String x:Key="TxtHelpFaqContent">If you encounter problems, check these common solutions first.</x:String>
    <x:String x:Key="TxtHelpFaqWhatLabel">What is OptiScaler?</x:String>
    <x:String x:Key="TxtHelpFaqWhatText">OptiScaler is a mod that allows you to use different upscaling technologies (DLSS, FSR, XeSS) in games, even if they don't natively support them.</x:String>
    <x:String x:Key="TxtHelpFaqSafeLabel">Is this app safe to use?</x:String>
    <x:String x:Key="TxtHelpFaqSafeText">Yes, the app is completely safe. You can scan it on VirusTotal to confirm there are no threats, and since the project is open-source, the code is available for anyone to review if they wish.</x:String>
    <x:String x:Key="TxtHelpFaqNotDetLabel">Game not detected</x:String>
    <x:String x:Key="TxtHelpFaqNotDetText">Make sure the game is installed and try adding it manually using 'Add Manual' button. You can also check scan sources in Settings.</x:String>
    <x:String x:Key="TxtHelpFaqInstFailLabel">Installation failed</x:String>
    <x:String x:Key="TxtHelpFaqInstFailText">Ensure you have write permissions to the game directory. Try running the application as administrator if needed.</x:String>
    <x:String x:Key="TxtHelpFaqCrashLabel">Game crashes after installation</x:String>
    <x:String x:Key="TxtHelpFaqCrashText">Try a different OptiScaler version or profile. Some games may require specific configurations.</x:String>
    <x:String x:Key="TxtHelpFaqUpscLabel">Upscaling not working in-game</x:String>
    <x:String x:Key="TxtHelpFaqUpscText">Check that the game supports DLSS/FSR/XeSS natively. OptiScaler replaces existing upscaling implementations.</x:String>
    <x:String x:Key="TxtHelpFaqDllLabel">Optiscaler.dll or nvngx.dll not found and other errors.</x:String>
    <x:String x:Key="TxtHelpFaqDllText">Use the button to clear the cache from the settings; that should solve most problems.</x:String>
    <x:String x:Key="TxtHelpFaqDirtyFolderLabel">Game folder is still dirty with OptiScaler files after uninstall</x:String>
    <x:String x:Key="TxtHelpFaqDirtyFolderText">This happens when a previous installation was not properly tracked (e.g. a crash left orphan files). Recommended steps:</x:String>
    <x:String x:Key="TxtHelpFaqDirtyFolderStep1">First, try the per-game Folder Cleanup utility in the app (Game → Force Folder Cleanup).</x:String>
    <x:String x:Key="TxtHelpFaqDirtyFolderStep2">If Folder Cleanup doesn't resolve the issue, click Uninstall in the app, then manually delete any remaining OptiScaler files from the game folder (OptiScaler.dll, OptiScaler.ini, dxgi.dll if it was the injection target, nvapi64.dll, etc.).</x:String>
    <x:String x:Key="TxtHelpFaqDirtyFolderStep3">The app will also detect corrupt installations by default and will prompt to clean the folder before installing when needed.</x:String>
    <x:String x:Key="TxtHelpFaqFsr4LinuxLabel">FSR 4 not visible on Linux</x:String>
    <x:String x:Key="TxtHelpFaqFsr4LinuxText">If you are on Linux and FSR 4 does not appear as an option, consider the following:</x:String>
    <x:String x:Key="TxtHelpFaqFsr4LinuxStep1">You need the latest AMD MESA drivers (version 25.2.0 or newer).</x:String>
    <x:String x:Key="TxtHelpFaqFsr4LinuxStep2">Install the latest version of OptiScaler available.</x:String>
    <x:String x:Key="TxtHelpFaqFsr4LinuxStep3">It is recommended to use GE-Proton, which can be managed via Proton Plus or ProtonUp-Qt.</x:String>

    <!-- Help - Profile Bullets -->
    <x:String x:Key="TxtHelpProfDefaultTitle">Default profile</x:String>
    <x:String x:Key="TxtHelpProfDefaultText">Sets which profile will be selected by default when managing a game or using Quick Install.</x:String>
    <x:String x:Key="TxtHelpProfNameTitle">Profile name</x:String>
    <x:String x:Key="TxtHelpProfNameText">Sets the display name for your profile.</x:String>
    <x:String x:Key="TxtHelpProfDescTitle">Description</x:String>
    <x:String x:Key="TxtHelpProfDescText">Sets a description for your profile.</x:String>
    <x:String x:Key="TxtHelpProfModeTitle">Mode</x:String>
    <x:String x:Key="TxtHelpProfModeText">Choose between Easy and Advanced modes. Easy mode limits settings to the essentials for a quick and simple setup, ideal for beginners. Advanced mode allows full editing of the .ini file, offering total control and maximum customization for power users.</x:String>
    <x:String x:Key="TxtHelpProfNavTitle">Navigation section</x:String>
    <x:String x:Key="TxtHelpProfNavText">Allows you to navigate through the different sections of the profile editor.</x:String>
    <x:String x:Key="TxtHelpProfSearchTitle">Search bar</x:String>
    <x:String x:Key="TxtHelpProfSearchText">Allows you to search for specific settings within the profile editor.</x:String>

    <!-- Profile Management View -->
    <x:String x:Key="TxtProfViewTitle">Profiles</x:String>
