    <x:String x:Key="TxtWelcomeChangelogTitle">Changelog</x:String>
    <x:String x:Key="TxtWelcomeChangelogContent">See the full list of changes and new features for this version on GitHub.</x:String>
    <x:String x:Key="TxtWelcomeChangelogLink">&#x2197; View changelog on GitHub</x:String>
