    <x:String x:Key="TxtAnimations">Enable animations</x:String>
    <x:String x:Key="TxtAnimationsDesc">Enable smooth transitions and animations throughout the interface</x:String>
    <x:String x:Key="TxtBetaVersions">Prefer latest beta as default</x:String>
    <x:String x:Key="TxtBetaVersionsDesc">When enabled, automatically selects the latest beta version instead of the stable release.</x:String>
    <x:String x:Key="TxtBetaIncludesComponents">This version already includes Fakenvapi and NukemFG</x:String>
    <x:String x:Key="TxtFsr4Int8DefaultTitle">FSR4 INT8 Default</x:String>
    <x:String x:Key="TxtFsr4Int8DefaultDesc">Default FSR4 INT8 mod version pre-selected when opening a game. RDNA 4 GPUs (RX 9000 series) default to None automatically.</x:String>
    <x:String x:Key="TxtDefaultGpuTitle">Default GPU</x:String>
    <x:String x:Key="TxtDefaultGpuDesc">Used for defaults and GPU-specific guidance.</x:String>
    <x:String x:Key="TxtDefaultOptiVersionTitle">Default OptiScaler Version</x:String>
    <x:String x:Key="TxtDefaultOptiVersionDesc">Pre-selected version when opening Manage or using Quick Install. 'Auto' picks the latest recommended release.</x:String>
    <x:String x:Key="TxtDefaultVersionsTitle">Default Versions</x:String>
    <x:String x:Key="TxtDefaultVersionsDesc">Manage default component versions for game management and Quick Install</x:String>
    <x:String x:Key="TxtManageDefaultVersions">Manage Default Versions</x:String>
    <x:String x:Key="TxtManageDefaultVersionsDesc">Configure which component versions are pre-selected when opening the game management window or using Quick Install.</x:String>
    <x:String x:Key="TxtOptiPatcherDefaultTitle">Default OptiPatcher Version</x:String>
    <x:String x:Key="TxtOptiPatcherDefaultDesc">Pre-selected OptiPatcher version when opening Manage or using Quick Install. Select None to skip OptiPatcher installation.</x:String>
    <x:String x:Key="TxtOptiPatcherSupportLinkText">View supported games list</x:String>
    <x:String x:Key="TxtClearAppCacheTitle">Clear Application Cache</x:String>
    <x:String x:Key="TxtClearAppCacheDesc">Remove scanned games, cover art and cached version data. The app will re-scan and re-download on next launch.</x:String>
    <x:String x:Key="TxtClearCacheBtn">Clear Cache</x:String>
    <x:String x:Key="TxtClearAppCacheDialogMsg">Warning: This will permanently delete all scanned games, cover art and cached OptiScaler version data.&#x0a;&#x0a;The application will close after clearing. On the next launch it will re-scan your library and re-download version information.</x:String>

    <!-- Scan Sources -->
