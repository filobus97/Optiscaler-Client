    <x:String x:Key="TxtSteamGridApiKeyPlaceholder">Paste your SteamGridDB API key here</x:String>
    <x:String x:Key="TxtSteamGridGuideStep3Title">3. Paste it in Settings</x:String>
    <x:String x:Key="TxtSteamGridGuideStep3Desc">Return to the app and paste the key into the SteamGridDB API Key field.</x:String>

    <x:String x:Key="TxtSteamGridGuideStep1Prefix">Go to </x:String>
    <x:String x:Key="TxtSteamGridGuideStep1Suffix"> and sign in.</x:String>

    <!-- Network / Proxy Settings -->
    <x:String x:Key="TxtNetworkTitle">Network &amp; Proxy</x:String>
    <x:String x:Key="TxtNetworkDesc">Configure an HTTP(S) proxy for GitHub API and download connections.</x:String>
    <x:String x:Key="TxtNetworkWindowDesc">Configure an HTTP(S) or SOCKS5 proxy for GitHub API and download connections. Leave blank to use the system proxy.</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxy">Use system proxy</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxyDesc">When enabled, the OS proxy settings and HTTP_PROXY / HTTPS_PROXY environment variables are used. Disable to set a custom proxy below.</x:String>
