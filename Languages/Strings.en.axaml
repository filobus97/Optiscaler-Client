    <x:String x:Key="TxtCoverRefreshDoneFmt">Cover refresh complete. Found {0}/{1} missing covers.</x:String>
    <x:String x:Key="TxtCoverRefreshToastFmt">Cover refresh complete — {0}/{1} covers found.</x:String>

    <!-- OptiPatcher -->
    <x:String x:Key="TxtOptiPatcherLbl">OptiPatcher</x:String>
    <x:String x:Key="TxtOptiPatcherTooltip">An ASI Plugin for OptiScaler that exposes DLSS/DLSS-FG inputs without spoofing in supported games. Helps AMD and Intel users avoid D3D12 errors and prevents performance overhead or crashes caused by Dxgi spoofing.</x:String>
    <x:String x:Key="TxtDownloadingOptiPatcher">Downloading OptiPatcher...</x:String>
    <x:String x:Key="TxtInstallingOptiPatcher">Installing OptiPatcher...</x:String>
    <x:String x:Key="TxtVersionMgmtInfoTitle">Version Management</x:String>
    <x:String x:Key="TxtVersionMgmtInfoDesc">OptiScaler, OptiPatcher, FSR4 INT8, Fakenvapi and NukemFG versions can be managed from the Local cache &amp; Default version management section in Settings.</x:String>
