    <x:String x:Key="TxtAnimationsDesc">Włącz płynne przejścia i animacje w całym interfejsie</x:String>
    <x:String x:Key="TxtBetaVersions">Pokaż wersje beta</x:String>
    <x:String x:Key="TxtBetaVersionsDesc">Uwzględnij wersje beta OptiScaler w selektorze. Wersje beta mogą być niestabilne.</x:String>

    <!-- Scan Sources -->
    <x:String x:Key="TxtManageScanSources">Zarządzaj źródłami skanowania</x:String>
    <x:String x:Key="TxtManageScanSourcesDesc">Skonfiguruj, które platformy i foldery skanować w poszukiwaniu gier</x:String>
    <x:String x:Key="TxtDefaultSources">Źródła domyślne</x:String>
    <x:String x:Key="TxtCustomFolders">Niestandardowe foldery</x:String>
    <x:String x:Key="TxtAddFolder">+ Dodaj folder</x:String>
    <x:String x:Key="TxtNoCustomFolders">Nie dodano jeszcze żadnych niestandardowych folderów.</x:String>
    <x:String x:Key="TxtFilterOptions">Opcje filtrowania</x:String>
    <x:String x:Key="TxtFilterShowAllTitle">Skanuj wszystkie gry</x:String>
    <x:String x:Key="TxtFilterShowAllDesc">Wykrywaj i wyświetlaj wszystkie zainstalowane gry ze wszystkich włączonych źródeł.</x:String>
    <x:String x:Key="TxtFilterHideTitle">Skanuj wszystko, ukryj bez upscalerów</x:String>
    <x:String x:Key="TxtFilterHideDesc">Skanuj wszystko, ale automatycznie ukryj gry bez wykrywalnych DLSS, FSR lub XeSS. Ukryte gry pozostają na liście i mogą być pokazane z trybu Organizuj.</x:String>
    <x:String x:Key="TxtFilterSkipTitle">Pomiń gry bez upscalerów</x:String>
    <x:String x:Key="TxtFilterSkipDesc">Uwzględniaj tylko gry, w których wykryto pliki DLL DLSS, FSR lub XeSS.</x:String>
    <x:String x:Key="TxtFilterSkipWarning">Niektóre gry obsługują upscalery, ale nie ujawniają swoich plików DLL w wykrywalnej ścieżce. Te gry nie pojawią się na liście.</x:String>
    <x:String x:Key="TxtShowNonGameApps">Pokaż gry bez upscalerów (DLSS/FSR/XeSS)</x:String>
    <x:String x:Key="TxtRemove">Usuń</x:String>
    <x:String x:Key="TxtSave">Zapisz</x:String>
    <x:String x:Key="TxtScanSources">Źródła skanowania</x:String>
    <x:String x:Key="TxtScanSourcesDesc">Zarządzaj platformami i niestandardowymi folderami do skanowania</x:String>

    <!-- App Update -->
    <x:String x:Key="TxtUpdateAvailableTitle">Dostępna aktualizacja</x:String>
    <x:String x:Key="TxtUpdateAvailableMsg">Nowa wersja Optiscaler Client jest dostępna (v{0}).&#x0a;Czy chcesz pobrać i zainstalować ją teraz?</x:String>
