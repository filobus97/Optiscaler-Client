    <x:String x:Key="TxtAboutTitle">Pomoc</x:String>
    <x:String x:Key="TxtFeedbackTitle">Opinie</x:String>
    <x:String x:Key="TxtFeedbackDesc">Jeśli chcesz zgłosić funkcje lub zgłosić błędy, proszę otworzyć issue w repozytorium GitHub.</x:String>
