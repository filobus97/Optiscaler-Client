<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <x:String x:Key="TxtSettingsTitle">Ustawienia</x:String>
    <x:String x:Key="TxtSettingsDesc">Zarządzaj preferencjami aplikacji</x:String>
    <x:String x:Key="TxtAppPrefs">Preferencje aplikacji</x:String>
    <x:String x:Key="TxtCacheMgmt">Lokalna pamięć podręczna &amp; Zarządzanie wersjami domyślnymi</x:String>
    <x:String x:Key="TxtCacheDesc">Przeglądaj i zarządzaj pobranymi wersjami komponentów, ustawiaj domyślne wersje dla szybkiej instalacji i zarządzania grami oraz zwalniaj lokalną przestrzeń dyskową.</x:String>
    <x:String x:Key="TxtManage">&#xE8B7;  Zarządzaj</x:String>
    <x:String x:Key="TxtLanguage">Język aplikacji</x:String>
    <x:String x:Key="TxtLanguageDesc">Zmień język interfejsu użytkownika.</x:String>
    <x:String x:Key="TxtClose">Zamknij</x:String>
    <x:String x:Key="TxtGotIt">Rozumiem</x:String>
    <x:String x:Key="TxtAppRepoTitle">Repozytorium aplikacji</x:String>
    <x:String x:Key="TxtAppRepoDesc">Docelowe repozytorium GitHub dla aktualizacji i opinii (Właściciel/NazwaRepozytorium).</x:String>
    <!-- Guide Window -->
    <x:String x:Key="TxtGuideTitle">Przewodnik</x:String>
    <x:String x:Key="TxtGuideHeader">Jak używać Optiscaler Client</x:String>
    <x:String x:Key="TxtGuideHeaderDesc">Proste kroki do ulepszenia swoich gier</x:String>
    <x:String x:Key="TxtGuideStep1Title">1. Znajdź swoje gry</x:String>
    <x:String x:Key="TxtGuideStep1Desc">Kliknij przycisk 'Skanuj gry', aby aplikacja automatycznie znalazła zainstalowane gry z Steam, Epic, GOG lub Xbox. Zaznacz przycisk 'Dodaj ręcznie', jeśli masz samodzielną grę.</x:String>
    <x:String x:Key="TxtGuideStep2Title">2. Zarządzaj grą</x:String>
    <x:String x:Key="TxtGuideStep2Desc">Obok swojej gry na liście kliknij 'Zarządzaj'. Otworzy się okno pozwalające zainstalować lub zaktualizować modyfikację OptiScaler dla tej konkretnej gry.</x:String>
    <x:String x:Key="TxtGuideStep3Title">3. Zainstaluj OptiScaler</x:String>
    <x:String x:Key="TxtGuideStep3Desc">Wewnątrz okna zarządzania wybierz swoją wersję OptiScaler i opcje. Użyj 'Automatyczna instalacja' dla szybkiej konfiguracji. Jeśli automatyczna instalacja nie powiedzie się lub nie znajdzie poprawnego pliku wykonywalnego (.exe), użyj 'Ręczna instalacja', aby samodzielnie wybrać plik wykonywalny gry.</x:String>
    <x:String x:Key="TxtGuideStep4Title">4. Graj w grę</x:String>
    <x:String x:Key="TxtGuideStep4Desc">Po zainstalowaniu uruchom swoją grę normalnie. Wewnątrz gry otwórz menu OptiScaler, używając klawisza 'Insert', aby dostosować swoje ustawienia!</x:String>

    <!-- MainWindow -->
    <x:String x:Key="TxtAppTitle">Optiscaler Client Next</x:String>
    <x:String x:Key="TxtBtnScan">⟳  Skanuj gry</x:String>
    <x:String x:Key="TxtBtnAddManual">＋  Dodaj ręcznie</x:String>
    <x:String x:Key="TxtTipSettings">Ustawienia</x:String>
    <x:String x:Key="TxtTipComponent">Wersje komponentów</x:String>
    <x:String x:Key="TxtUpdateNukem">↑  Aktualizuj NukemFG</x:String>
    <x:String x:Key="TxtTipUpdateNukem">Nowa wersja NukemFG jest dostępna. Kliknij, aby dostarczyć zaktualizowaną DLL.</x:String>
    <x:String x:Key="TxtDefaultGpu">Wykrywanie GPU…</x:String>
    <x:String x:Key="TxtManageGame">Zarządzaj</x:String>
    <x:String x:Key="TxtQuickInstall">✦ Szybka instalacja</x:String>
    <x:String x:Key="TxtQuickUninstall">🗑️ Szybkie odinstalowanie</x:String>
    <x:String x:Key="TxtInitialScanTitle">Pierwsze skanowanie</x:String>
    <x:String x:Key="TxtInitialScanDesc">Zanim zeskanujemy dyski w poszukiwaniu gier, wybierz dyski i źródła. Możesz zamknąć to okno i zeskanować później.</x:String>
    <x:String x:Key="TxtScanSetupTitle">Ustawienia skanowania</x:String>
    <x:String x:Key="TxtScanSetupDesc">Wybierz dyski i źródła do skanowania. Możesz zamknąć to okno i zeskanować później.</x:String>
    <x:String x:Key="TxtInitialScanDrives">Dyski do skanowania</x:String>
    <x:String x:Key="TxtInitialScanSources">Źródła do skanowania</x:String>
    <x:String x:Key="TxtInitialScanStart">Rozpocznij skanowanie</x:String>
    <x:String x:Key="TxtInitialScanClose">Zamknij</x:String>
    <x:String x:Key="TxtInitialScanNoDrives">Nie wykryto dysków.</x:String>
    <x:String x:Key="TxtStatusReady">Gotowe</x:String>
    <x:String x:Key="TxtScanningTitle">Skanowanie gier...</x:String>
    <x:String x:Key="TxtScanningDesc">Wyszukiwanie gier na wszystkich platformach...</x:String>
    <x:String x:Key="TxtSearchGames">Szukaj gier...</x:String>
    <x:String x:Key="TxtRemoveGameTip">Usuń ręcznie dodaną grę</x:String>
    <x:String x:Key="TxtRemoveGameTitle">Usuń grę</x:String>
    <x:String x:Key="TxtRemoveGameConfirm">Czy na pewno chcesz usunąć '{0}' z listy?</x:String>

    <!-- ManageCacheWindow -->
    <x:String x:Key="TxtManageCacheTitle">Zarządzaj lokalnymi wersjami</x:String>
    <x:String x:Key="TxtLocalVersions">Lokalne wersje</x:String>
    <x:String x:Key="TxtManageCacheDesc">Zarządzaj pobraną pamięcią podręczną OptiScaler</x:String>
    <x:String x:Key="TxtDownloadedVersions">Pobrane wersje OptiScaler:</x:String>
    <x:String x:Key="TxtDeleteIcon">🗑️ Usuń</x:String>
    <x:String x:Key="TxtNoVersions">Obecnie nie ma pobranych wersji.</x:String>
    <x:String x:Key="TxtToastSuccess">Sukces</x:String>
    <x:String x:Key="TxtConfirmDelTitle">Potwierdź usunięcie</x:String>
    <x:String x:Key="TxtCustomVersions">Niestandardowe wersje OptiScaler</x:String>
    <x:String x:Key="TxtImportArchive">Importuj archiwum</x:String>
    <x:String x:Key="TxtNoCustomVersions">Nie zaimportowano żadnych niestandardowych wersji.</x:String>
    <x:String x:Key="TxtCustomVersionWarning">⚠ Importuj niestandardowe buildy OptiScaler jako archiwa 7z, zip lub rar. Instalacja/deinstalacja może się nie powieść, jeśli archiwum zawiera pliki nieśledzalne przez aplikację. Dołącz tylko pliki wydania OptiScaler.</x:String>
    <x:String x:Key="TxtImporting">Importowanie...</x:String>
    <x:String x:Key="TxtConfirmDelMsg">Czy na pewno chcesz usunąć tę wersję?</x:String>
    <x:String x:Key="TxtCancel">Anuluj</x:String>
    <x:String x:Key="TxtDeletePlain">Usuń</x:String>
    <x:String x:Key="TxtConfirmDelFormat">Czy na pewno chcesz usunąć OptiScaler v{0} z lokalnego magazynu?</x:String>
    <x:String x:Key="TxtDeletedSuccessFormat">OptiScaler v{0} został pomyślnie usunięty.</x:String>
    <x:String x:Key="TxtFailedDeleteFormat">Nie udało się usunąć wersji: {0}</x:String>
    <x:String x:Key="TxtError">Błąd</x:String>
    <x:String x:Key="TxtCurrentSelection">Obecnie wybrane</x:String>
    <x:String x:Key="TxtVersionStored">1 wersja przechowywana lokalnie.</x:String>
    <x:String x:Key="TxtVersionsStored">{0} wersji przechowywanych lokalnie.</x:String>

    <!-- ComponentInfoWindow -->
    <x:String x:Key="TxtComponentTitle">Wersje komponentów</x:String>
    <x:String x:Key="TxtComponentDesc">Zainstalowane wersje zestawu narzędzi OptiScaler</x:String>
    <x:String x:Key="TxtBtnGuide">📖 Przewodnik</x:String>
    <x:String x:Key="TxtUpdateAvail">Aktualizacja dostępna</x:String>
