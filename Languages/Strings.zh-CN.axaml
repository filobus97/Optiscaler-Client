    <!-- OptiPatcher -->
    <x:String x:Key="TxtOptiPatcherLbl">OptiPatcher</x:String>
    <x:String x:Key="TxtOptiPatcherTooltip">OptiScaler 的 ASI 插件，在受支持的游戏中无需欺骗即可暴露 DLSS/DLSS-FG 输入。帮助 Intel Arc 用户避免 D3D12 错误，并防止 Dxgi 欺骗导致的性能开销或崩溃。</x:String>
    <x:String x:Key="TxtDownloadingOptiPatcher">正在下载 OptiPatcher...</x:String>
    <x:String x:Key="TxtInstallingOptiPatcher">正在安装 OptiPatcher...</x:String>
    <x:String x:Key="TxtVersionMgmtInfoTitle">版本管理</x:String>
    <x:String x:Key="TxtVersionMgmtInfoDesc">OptiScaler、OptiPatcher、FSR4 INT8、Fakenvapi 和 NukemFG 的版本可以在设置中的本地缓存和默认版本管理部分进行管理。</x:String>
    <x:String x:Key="TxtSetDefault">设为默认</x:String>
    <x:String x:Key="TxtClearDefault">清除</x:String>
