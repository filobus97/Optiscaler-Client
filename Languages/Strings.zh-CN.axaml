    <!-- SteamGridDB -->
    <x:String x:Key="TxtSteamGridGuideStep1Title">1. Open the SteamGridDB API page</x:String>
    <x:String x:Key="TxtSteamGridApiKeyDesc">用于提高封面匹配准确性。可选，但建议填写。</x:String>
    <x:String x:Key="TxtSteamGridGuideStep2Title">2. 生成您的 API 密钥</x:String>
    <x:String x:Key="TxtSteamGridGuideStep1Desc">访问 https://www.steamgriddb.com/profile/preferences/api 并登录。</x:String>
    <x:String x:Key="TxtSteamGridGuideStep4Desc">保存密钥后运行新的扫描，以便更准确地刷新封面。</x:String>
    <x:String x:Key="TxtSteamGridGetApiKey">获取 API 密钥</x:String>
    <x:String x:Key="TxtSteamGridGuideStep2Desc">在该页面创建新的 API 密钥并复制它。</x:String>
    <x:String x:Key="TxtSteamGridGuideOpenPage">打开页面</x:String>
    <x:String x:Key="TxtSteamGridGuideStep4Title">4. 重新扫描您的游戏</x:String>
    <x:String x:Key="TxtSteamGridGuideHeader">Get your SteamGridDB API Key</x:String>
    <x:String x:Key="TxtSteamGridGuideTitle">SteamGridDB API Key</x:String>
    <x:String x:Key="TxtSteamGridGuideHeaderDesc">快速指南以提高游戏封面检测的准确性。</x:String>
    <x:String x:Key="TxtSteamGridApiKey">SteamGridDB API Key</x:String>
    <x:String x:Key="TxtSteamGridApiKeyPlaceholder">Paste your SteamGridDB API key here</x:String>
    <x:String x:Key="TxtSteamGridGuideStep3Title">3. 将其粘贴到设置中</x:String>
    <x:String x:Key="TxtSteamGridGuideStep3Desc">Return to the app and paste the key into the SteamGridDB API Key field.</x:String>

    <x:String x:Key="TxtSteamGridGuideStep1Prefix">访问 </x:String>
    <x:String x:Key="TxtSteamGridGuideStep1Suffix"> 并登录。</x:String>

    <x:String x:Key="TxtViewGrid">网格视图</x:String>
    <x:String x:Key="TxtViewList">列表视图</x:String>
    <x:String x:Key="TxtLoadingResources">正在加载资源...</x:String>
    <x:String x:Key="TxtLoadingResourcesDesc">Fetching version data from GitHub</x:String>
    <x:String x:Key="TxtEditImage">编辑图片</x:String>
    <x:String x:Key="TxtCoverUpdateTitle">更新封面</x:String>
    <x:String x:Key="TxtCoverUpdateDesc">为游戏选择自定义图片。</x:String>
    <x:String x:Key="TxtPreviewUnavailable">预览不可用</x:String>
    <x:String x:Key="TxtCoverRestoreTooltip">恢复为游戏的默认封面图片</x:String>
    <x:String x:Key="TxtRestore">恢复</x:String>
