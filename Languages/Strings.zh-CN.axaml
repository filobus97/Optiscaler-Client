<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <x:String x:Key="TxtSettingsTitle">设置</x:String>
    <x:String x:Key="TxtSettingsDesc">管理应用程序首选项</x:String>
    <x:String x:Key="TxtAppPrefs">应用首选项</x:String>
    <x:String x:Key="TxtCacheMgmt">本地缓存管理</x:String>
    <x:String x:Key="TxtCacheDesc">查看并删除本地存储中已下载的 OptiScaler 版本以释放空间</x:String>
    <x:String x:Key="TxtManage">&#xE8B7;  管理</x:String>
    <x:String x:Key="TxtLanguage">应用程序语言</x:String>
    <x:String x:Key="TxtLanguageDesc">更改用户界面语言</x:String>
    <x:String x:Key="TxtClose">关闭</x:String>
    <x:String x:Key="TxtGotIt">确定</x:String>
    <x:String x:Key="TxtAppRepoTitle">应用仓库</x:String>
    <x:String x:Key="TxtAppRepoDesc">用于更新和反馈的目标 GitHub 仓库（所有者/仓库名）。</x:String>
    <!-- Guide Window -->
    <x:String x:Key="TxtGuideTitle">指南</x:String>
    <x:String x:Key="TxtGuideHeader">如何使用 Optiscaler Client</x:String>
    <x:String x:Key="TxtGuideHeaderDesc">增强游戏的简单步骤</x:String>
    <x:String x:Key="TxtGuideStep1Title">1. 找到游戏</x:String>
    <x:String x:Key="TxtGuideStep1Desc">点击「扫描游戏」按钮，让应用程序从 Steam、Epic、GOG 或 Xbox 自动查找已安装游戏。如果有其它游戏，请使用「手动添加」</x:String>
    <x:String x:Key="TxtGuideStep2Title">2. 管理游戏</x:String>
    <x:String x:Key="TxtGuideStep2Desc">在列表中游戏右侧，点击「管理」，将打开管理窗口，允许为该特定游戏安装或更新 OptiScaler</x:String>
    <x:String x:Key="TxtGuideStep3Title">3. 安装 OptiScaler</x:String>
    <x:String x:Key="TxtGuideStep3Desc">在管理窗口内，选择 OptiScaler 版本和选项，使用「自动安装」进行快速设置；如果自动安装失败或无法找到正确的可执行文件（.exe），请使用「手动安装」选择游戏的可执行文件。</x:String>
    <x:String x:Key="TxtGuideStep4Title">4. 游玩</x:String>
    <x:String x:Key="TxtGuideStep4Desc">安装后，正常启动游戏，在游戏内，使用「Insert」键打开 OptiScaler 菜单面板来调整设置！</x:String>

    <!-- MainWindow -->
    <x:String x:Key="TxtAppTitle">Optiscaler Client Next</x:String>
    <x:String x:Key="TxtBtnScan">⟳  扫描游戏</x:String>
    <x:String x:Key="TxtBtnAddManual">＋  手动添加</x:String>
