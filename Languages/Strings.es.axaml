    <x:String x:Key="TxtNetworkProxyPort">Puerto</x:String>
    <x:String x:Key="TxtNetworkProxyPortPlaceholder">3128</x:String>
    <x:String x:Key="TxtNetworkRequiresAuth">El proxy requiere autenticación</x:String>
