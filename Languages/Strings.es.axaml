    <x:String x:Key="TxtOptiUninstallFail">Error en la desinstalación: {0}</x:String>

    <!-- ManualDownloadDialog -->
    <x:String x:Key="TxtManualTitle">Archivo Manual Requerido</x:String>
    <x:String x:Key="TxtDownloadFrom">Descargar desde: </x:String>
