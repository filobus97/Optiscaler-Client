    <x:String x:Key="TxtInitialScanStart">Iniciar escaneo</x:String>
    <x:String x:Key="TxtInitialScanClose">Cerrar</x:String>
    <x:String x:Key="TxtInitialScanNoDrives">No se detectaron unidades.</x:String>
