    <!-- Games View - Scan & Organize -->
    <x:String x:Key="TxtSkipNoDllsTitle">Omitir juegos sin DLLs de escalado</x:String>
    <x:String x:Key="TxtSkipNoDllsDesc">Ignora juegos que no tienen bibliotecas detectables de DLSS, FSR o XeSS. Solo se agregarán juegos compatibles con OptiScaler.</x:String>
    <x:String x:Key="TxtRefreshCoversTitle">Actualizar solo portadas faltantes</x:String>
    <x:String x:Key="TxtRefreshCoversDesc">Omite el escaneo completo y reintenta obtener las portadas de los juegos que no pudieron descargarse antes. Util despues de configurar una clave de API de SteamGridDB.</x:String>
    <x:String x:Key="TxtOrganizeGamesTooltip">Organizar juegos</x:String>
    <x:String x:Key="TxtOrganizeModeBanner">Modo organizacion</x:String>
    <x:String x:Key="TxtOrganizeModeReorder">▲▼ reordenar</x:String>
    <x:String x:Key="TxtOrganizeModeHideShow">mostrar/ocultar</x:String>
    <x:String x:Key="TxtOrganizeModeDone">Listo</x:String>
    <x:String x:Key="TxtDragToReorder">Arrastra para reordenar</x:String>
    <x:String x:Key="TxtMoveUp">Mover arriba</x:String>
    <x:String x:Key="TxtMoveDown">Mover abajo</x:String>
    <x:String x:Key="TxtHideShowGame">Ocultar/mostrar juego</x:String>
    <x:String x:Key="TxtHideGame">Ocultar</x:String>
    <x:String x:Key="TxtShowGame">Mostrar</x:String>
    <x:String x:Key="TxtRefreshingCovers">Actualizando portadas faltantes...</x:String>
    <x:String x:Key="TxtCoverRefreshDoneFmt">Actualizacion de portadas completada. Se encontraron {0}/{1} portadas faltantes.</x:String>
    <x:String x:Key="TxtCoverRefreshToastFmt">Actualizacion de portadas completada — {0}/{1} portadas encontradas.</x:String>

    <!-- OptiPatcher -->
    <x:String x:Key="TxtOptiPatcherLbl">OptiPatcher</x:String>
    <x:String x:Key="TxtOptiPatcherTooltip">Plugin ASI para OptiScaler que expone las entradas DLSS/DLSS-FG sin spoofing en juegos compatibles. Ayuda a los usuarios de Intel Arc a evitar errores D3D12 y previene el consumo de rendimiento o crashes causados por el Dxgi spoofing.</x:String>
    <x:String x:Key="TxtDownloadingOptiPatcher">Descargando OptiPatcher...</x:String>
    <x:String x:Key="TxtInstallingOptiPatcher">Instalando OptiPatcher...</x:String>
    <x:String x:Key="TxtVersionMgmtInfoTitle">Gestión de versiones</x:String>
    <x:String x:Key="TxtVersionMgmtInfoDesc">Las versiones de OptiScaler, OptiPatcher, FSR4 INT8, Fakenvapi y NukemFG se pueden gestionar desde la sección Caché local y versiones predeterminadas en Configuración.</x:String>
    <x:String x:Key="TxtSetDefault">Predeterminar</x:String>
    <x:String x:Key="TxtClearDefault">Limpiar</x:String>
    <x:String x:Key="TxtDefaultBadge">PREDETERMINADO</x:String>
    <x:String x:Key="TxtCurrentDefaultFormat">Predeterminado actual: {0}</x:String>
    <x:String x:Key="TxtNoDefaultSet">Sin versión predeterminada</x:String>

    <!-- Welcome popup -->
    <x:String x:Key="TxtWelcomeChangelogTitle">Historial de Cambios</x:String>
    <x:String x:Key="TxtWelcomeChangelogContent">Podés ver la lista completa de cambios y novedades de esta versión en GitHub.</x:String>
    <x:String x:Key="TxtWelcomeChangelogLink">&#x2197; Ver historial en GitHub</x:String>
    <x:String x:Key="TxtWelcomeGuideTitle">Guía de Inicio</x:String>
    <x:String x:Key="TxtWelcomeGuideContent">Te recomiendo encarecidamente revisar la guía integrada en la pestaña de Ayuda para orientarte con la app o resolver cualquier duda puntual.</x:String>
</ResourceDictionary>



