    <x:String x:Key="TxtEditorCancel">Iptal</x:String>
    <x:String x:Key="TxtEditorSave">Profili kaydet</x:String>

    <!-- Games View - Scan & Organize -->
    <x:String x:Key="TxtSkipNoDllsTitle">Ölçekleme DLL'leri olmayan oyunları atla</x:String>
    <x:String x:Key="TxtSkipNoDllsDesc">Algılanabilir DLSS, FSR veya XeSS kütüphaneleri olmayan oyunları yok say. Yalnızca OptiScaler ile uyumlu oyunlar eklenecektir.</x:String>
    <x:String x:Key="TxtRefreshCoversTitle">Yalnizca eksik kapaklari yenile</x:String>
    <x:String x:Key="TxtRefreshCoversDesc">Tam taramayi atlar ve yalnizca daha once alinamayan oyunlarin kapak gorsellerini yeniden dener. SteamGridDB API anahtari ayarlandiktan sonra kullanislidir.</x:String>
    <x:String x:Key="TxtOrganizeGamesTooltip">Oyunlari duzenle</x:String>
    <x:String x:Key="TxtOrganizeModeBanner">Duzenleme modu</x:String>
    <x:String x:Key="TxtOrganizeModeReorder">▲▼ yeniden sirala</x:String>
    <x:String x:Key="TxtOrganizeModeHideShow">goster/gizle</x:String>
    <x:String x:Key="TxtOrganizeModeDone">Tamam</x:String>
    <x:String x:Key="TxtDragToReorder">Yeniden siralamak icin sur</x:String>
    <x:String x:Key="TxtMoveUp">Yukari tas</x:String>
    <x:String x:Key="TxtMoveDown">Asagi tas</x:String>
    <x:String x:Key="TxtHideShowGame">Oyunu goster/gizle</x:String>
    <x:String x:Key="TxtHideGame">Gizle</x:String>
    <x:String x:Key="TxtShowGame">Göster</x:String>
    <x:String x:Key="TxtRefreshingCovers">Eksik kapaklar yenileniyor...</x:String>
    <x:String x:Key="TxtCoverRefreshDoneFmt">Kapak yenileme tamamlandi. {0}/{1} eksik kapak bulundu.</x:String>
    <x:String x:Key="TxtCoverRefreshToastFmt">Kapak yenileme tamamlandi — {0}/{1} kapak bulundu.</x:String>

    <!-- OptiPatcher -->
    <x:String x:Key="TxtOptiPatcherLbl">OptiPatcher</x:String>
    <x:String x:Key="TxtOptiPatcherTooltip">Desteklenen oyunlarda spoofing olmadan DLSS/DLSS-FG girişlerini açığa çıkaran OptiScaler için bir ASI Eklentisi. Intel Arc kullanıcılarının D3D12 hatalarından kaçınmasına yardımcı olur ve Dxgi spoofing'in neden olduğu performans düşüşlerini veya çökmeleri önler.</x:String>
    <x:String x:Key="TxtDownloadingOptiPatcher">OptiPatcher indiriliyor...</x:String>
    <x:String x:Key="TxtInstallingOptiPatcher">OptiPatcher yükleniyor...</x:String>
    <x:String x:Key="TxtVersionMgmtInfoTitle">Sürüm Yönetimi</x:String>
    <x:String x:Key="TxtVersionMgmtInfoDesc">OptiScaler, OptiPatcher, FSR4 INT8, Fakenvapi ve NukemFG sürümleri Ayarlar'daki Yerel önbellek &amp; Varsayılan sürüm yönetimi bölümünden yönetilebilir.</x:String>
    <x:String x:Key="TxtSetDefault">Varsayılan Yap</x:String>
    <x:String x:Key="TxtClearDefault">Temizle</x:String>
    <x:String x:Key="TxtDefaultBadge">VARSAYILAN</x:String>
    <x:String x:Key="TxtCurrentDefaultFormat">Mevcut varsayılan: {0}</x:String>
    <x:String x:Key="TxtNoDefaultSet">Varsayılan ayarlanmadı</x:String>
    <!-- Network / Proxy Settings -->
    <x:String x:Key="TxtNetworkTitle">Ağ ve Proxy</x:String>
    <x:String x:Key="TxtNetworkDesc">GitHub API ve indirme bağlantıları için HTTP(S) proxy yapılandırın.</x:String>
    <x:String x:Key="TxtNetworkWindowDesc">GitHub API ve indirme bağlantıları için HTTP(S) veya SOCKS5 proxy yapılandırın. Sistem proxy'sini kullanmak için boş bırakın.</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxy">Sistem proxy'sini kullan</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxyDesc">Etkinse, işletim sistemi proxy ayarları ve HTTP_PROXY / HTTPS_PROXY ortam değişkenleri kullanılır. Özel proxy ayarlamak için devre dışı bırakın.</x:String>
    <x:String x:Key="TxtNetworkProxyConfig">Proxy Yapılandırması</x:String>
    <x:String x:Key="TxtNetworkProxyType">Tür</x:String>
    <x:String x:Key="TxtNetworkProxyHost">Host</x:String>
    <x:String x:Key="TxtNetworkProxyHostPlaceholder">proxy.ornek.com</x:String>
    <x:String x:Key="TxtNetworkProxyPort">Port</x:String>
    <x:String x:Key="TxtNetworkProxyPortPlaceholder">3128</x:String>
    <x:String x:Key="TxtNetworkRequiresAuth">Proxy kimlik doğrulama gerektirir</x:String>
    <x:String x:Key="TxtNetworkCredentials">Kimlik bilgileri</x:String>
    <x:String x:Key="TxtNetworkUsername">Kullanıcı adı</x:String>
    <x:String x:Key="TxtNetworkUsernamePlaceholder">İsteğe bağlı</x:String>
    <x:String x:Key="TxtNetworkPassword">Parola</x:String>
    <x:String x:Key="TxtNetworkPasswordPlaceholder">İsteğe bağlı</x:String>
    <x:String x:Key="TxtNetworkTestBtn">Bağlantıyı test et</x:String>
    <x:String x:Key="TxtNetworkTestOk">✓ Bağlandı</x:String>
    <x:String x:Key="TxtNetworkTestFail">✗ Başarısız</x:String>
    <x:String x:Key="TxtNetworkTestTesting">Test ediliyor…</x:String>

    <!-- Welcome popup -->
    <x:String x:Key="TxtWelcomeChangelogTitle">Değişiklik Günlüğü</x:String>
    <x:String x:Key="TxtWelcomeChangelogContent">Bu sürümün tüm değişikliklerinin ve yeni özelliklerinin tam listesini GitHub&apos;da görebilirsiniz.</x:String>
    <x:String x:Key="TxtWelcomeChangelogLink">&#x2197; GitHub&apos;da değişiklik günlüğünü görüntüle</x:String>
    <x:String x:Key="TxtWelcomeGuideTitle">Başlarken</x:String>
    <x:String x:Key="TxtWelcomeGuideContent">Uygulamaya alışmak veya belirli sorularınızı çözmek için Yardım sekmesindeki yerleşik kılavuzu incelemenizi şiddetle tavsiye ederim.</x:String>
</ResourceDictionary>



