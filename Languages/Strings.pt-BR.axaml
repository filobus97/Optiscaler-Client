    <x:String x:Key="TxtAutoScan">Escanear automaticamente ao iniciar</x:String>
    <x:String x:Key="TxtAutoScanDesc">Escanear automaticamente jogos ao iniciar o aplicativo</x:String>
    <x:String x:Key="TxtAnimations">Ativar animações</x:String>
    <x:String x:Key="TxtAnimationsDesc">Ativar transições suaves e animações em toda a interface</x:String>
    <x:String x:Key="TxtBetaVersions">Preferir último beta como padrão</x:String>
    <x:String x:Key="TxtBetaVersionsDesc">Quando ativado, seleciona automaticamente a última versão beta em vez da versão estável.</x:String>
    <x:String x:Key="TxtBetaIncludesComponents">Esta versão já inclui Fakenvapi e NukemFG</x:String>
    <x:String x:Key="TxtFsr4Int8DefaultTitle">Padrão FSR4 INT8</x:String>
    <x:String x:Key="TxtFsr4Int8DefaultDesc">Versão padrão do mod FSR4 INT8 pré-selecionada ao abrir um jogo. GPUs RDNA 4 (série RX 9000) usam Nenhum automaticamente.</x:String>
    <x:String x:Key="TxtDefaultGpuTitle">GPU padrão</x:String>
    <x:String x:Key="TxtDefaultGpuDesc">Usada para valores padrão e orientações específicas da GPU.</x:String>
    <x:String x:Key="TxtDefaultOptiVersionTitle">Versão padrão do OptiScaler</x:String>
    <x:String x:Key="TxtDefaultOptiVersionDesc">Versão pré-selecionada ao abrir Gerenciar ou usar Instalação Rápida. 'Auto' escolhe a versão mais recente recomendada.</x:String>
    <x:String x:Key="TxtDefaultVersionsTitle">Versões padrão</x:String>
    <x:String x:Key="TxtDefaultVersionsDesc">Gerenciar versões padrão dos componentes para gerenciamento de jogos e Instalação Rápida</x:String>
    <x:String x:Key="TxtManageDefaultVersions">Gerenciar versões padrão</x:String>
    <x:String x:Key="TxtManageDefaultVersionsDesc">Configure quais versões dos componentes são pré-selecionadas ao abrir a janela de gerenciamento de jogos ou ao usar Instalação Rápida.</x:String>
    <x:String x:Key="TxtOptiPatcherDefaultTitle">Versão padrão do OptiPatcher</x:String>
    <x:String x:Key="TxtOptiPatcherDefaultDesc">Versão do OptiPatcher pré-selecionada ao abrir Gerenciar ou usar Instalação Rápida. Selecione Nenhum para pular a instalação.</x:String>
    <x:String x:Key="TxtOptiPatcherSupportLinkText">Ver lista de jogos compatíveis</x:String>
    <x:String x:Key="TxtClearAppCacheTitle">Limpar cache da aplicação</x:String>
    <x:String x:Key="TxtClearAppCacheDesc">Remove jogos escaneados, capas e dados de versão em cache. O app irá reanalisar e baixar novamente no próximo início.</x:String>
    <x:String x:Key="TxtClearCacheBtn">Limpar cache</x:String>
    <x:String x:Key="TxtClearAppCacheDialogMsg">Atenção: Isso irá excluir permanentemente todos os jogos escaneados, capas e dados de versão do OptiScaler em cache.&#x0a;&#x0a;O aplicativo será fechado após a limpeza. No próximo início ele irá reanalisar sua biblioteca e baixar novamente as informações de versão.</x:String>

    <!-- Scan Sources -->
    <x:String x:Key="TxtManageScanSources">Gerenciar fontes de verificação</x:String>
    <x:String x:Key="TxtManageScanSourcesDesc">Configurar quais plataformas e pastas verificar para jogos</x:String>
