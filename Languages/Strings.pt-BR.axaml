    <!-- Welcome popup -->
    <x:String x:Key="TxtWelcomeChangelogTitle">Registro de Alterações</x:String>
    <x:String x:Key="TxtWelcomeChangelogContent">A lista completa de alterações e novidades desta versão está disponível no GitHub.</x:String>
    <x:String x:Key="TxtWelcomeChangelogLink">&#x2197; Ver registro de alterações no GitHub</x:String>
    <x:String x:Key="TxtWelcomeGuideTitle">Primeiros Passos</x:String>
    <x:String x:Key="TxtWelcomeGuideContent">Recomendo fortemente consultar o guia integrado na aba Ajuda para se orientar no app ou tirar dúvidas específicas.</x:String>
