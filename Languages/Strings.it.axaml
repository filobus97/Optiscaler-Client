    <!-- Games View - Scan & Organize -->
    <x:String x:Key="TxtSkipNoDllsTitle">Salta giochi senza DLL di upscaling</x:String>
    <x:String x:Key="TxtSkipNoDllsDesc">Ignora i giochi che non hanno librerie DLSS, FSR o XeSS rilevabili. Verranno aggiunti solo i giochi compatibili con OptiScaler.</x:String>
    <x:String x:Key="TxtRefreshCoversTitle">Aggiorna solo le copertine mancanti</x:String>
    <x:String x:Key="TxtRefreshCoversDesc">Salta la scansione completa e riprova solo a recuperare le copertine dei giochi che non e stato possibile scaricare in precedenza. Utile dopo aver configurato una chiave API SteamGridDB.</x:String>
    <x:String x:Key="TxtOrganizeGamesTooltip">Organizza giochi</x:String>
    <x:String x:Key="TxtOrganizeModeBanner">Modalita organizzazione</x:String>
    <x:String x:Key="TxtOrganizeModeReorder">▲▼ riordina</x:String>
    <x:String x:Key="TxtOrganizeModeHideShow">mostra/nascondi</x:String>
    <x:String x:Key="TxtOrganizeModeDone">Fatto</x:String>
    <x:String x:Key="TxtDragToReorder">Trascina per riordinare</x:String>
    <x:String x:Key="TxtMoveUp">Sposta su</x:String>
    <x:String x:Key="TxtMoveDown">Sposta giu</x:String>
    <x:String x:Key="TxtHideShowGame">Mostra/nascondi gioco</x:String>
    <x:String x:Key="TxtHideGame">Nascondi</x:String>
    <x:String x:Key="TxtShowGame">Mostra</x:String>
