    <x:String x:Key="TxtCoverRefreshDoneFmt">Aggiornamento copertine completato. Trovate {0}/{1} copertine mancanti.</x:String>
    <x:String x:Key="TxtCoverRefreshToastFmt">Aggiornamento copertine completato — {0}/{1} copertine trovate.</x:String>

    <!-- OptiPatcher -->
    <x:String x:Key="TxtOptiPatcherLbl">OptiPatcher</x:String>
    <x:String x:Key="TxtOptiPatcherTooltip">Plugin ASI per OptiScaler che espone gli input DLSS/DLSS-FG senza spoofing nei giochi supportati. Aiuta gli utenti Intel Arc a evitare errori D3D12 e previene cali di prestazioni o crash causati dallo spoofing Dxgi.</x:String>
    <x:String x:Key="TxtDownloadingOptiPatcher">Download di OptiPatcher...</x:String>
    <x:String x:Key="TxtInstallingOptiPatcher">Installazione di OptiPatcher...</x:String>
    <x:String x:Key="TxtVersionMgmtInfoTitle">Gestione delle versioni</x:String>
    <x:String x:Key="TxtVersionMgmtInfoDesc">Le versioni di OptiScaler, OptiPatcher, FSR4 INT8, Fakenvapi e NukemFG possono essere gestite dalla sezione Cache locale &amp; Gestione versioni predefinite nelle Impostazioni.</x:String>
    <x:String x:Key="TxtSetDefault">Imposta predefinito</x:String>
    <x:String x:Key="TxtClearDefault">Cancella</x:String>
    <x:String x:Key="TxtDefaultBadge">PREDEFINITO</x:String>
    <x:String x:Key="TxtCurrentDefaultFormat">Predefinito attuale: {0}</x:String>
    <x:String x:Key="TxtNoDefaultSet">Nessun predefinito impostato</x:String>
    <!-- Network / Proxy Settings -->
    <x:String x:Key="TxtNetworkTitle">Rete e Proxy</x:String>
    <x:String x:Key="TxtNetworkDesc">Configura un proxy HTTP(S) per l'API GitHub e le connessioni di download.</x:String>
    <x:String x:Key="TxtNetworkWindowDesc">Configura un proxy HTTP(S) o SOCKS5 per l'API GitHub e le connessioni di download. Lascia vuoto per usare il proxy di sistema.</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxy">Usa proxy di sistema</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxyDesc">Se abilitato, vengono utilizzate le impostazioni proxy del SO e le variabili d'ambiente HTTP_PROXY / HTTPS_PROXY. Disabilita per impostare un proxy personalizzato qui sotto.</x:String>
    <x:String x:Key="TxtNetworkProxyConfig">Configurazione proxy</x:String>
