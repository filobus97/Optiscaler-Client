    <!-- Scan Sources -->
    <x:String x:Key="TxtManageScanSources">Gestisci fonti di scansione</x:String>
    <x:String x:Key="TxtManageScanSourcesDesc">Configura quali piattaforme e cartelle scansionare per i giochi</x:String>
