<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <x:String x:Key="TxtSettingsTitle">設定</x:String>
    <x:String x:Key="TxtSettingsDesc">管理應用程式偏好設定</x:String>
    <x:String x:Key="TxtAppPrefs">應用程式偏好設定</x:String>
    <x:String x:Key="TxtCacheMgmt">本機快取與預設版本管理</x:String>
    <x:String x:Key="TxtCacheDesc">檢視和管理已下載的元件版本，設定快速安裝和遊戲管理的預設版本，並釋放本機儲存空間。</x:String>
    <x:String x:Key="TxtManage">&#xE8B7;  管理</x:String>
    <x:String x:Key="TxtLanguage">應用程式語言</x:String>
    <x:String x:Key="TxtLanguageDesc">變更使用者介面語言。</x:String>
    <x:String x:Key="TxtClose">關閉</x:String>
    <x:String x:Key="TxtGotIt">知道了</x:String>
    <x:String x:Key="TxtAppRepoTitle">應用程式儲存庫</x:String>
    <x:String x:Key="TxtAppRepoDesc">用於更新和回饋的目標GitHub儲存庫（擁有者/儲存庫名稱）。</x:String>
    <!-- Guide Window -->
    <x:String x:Key="TxtGuideTitle">指南</x:String>
    <x:String x:Key="TxtGuideHeader">如何使用Optiscaler Client</x:String>
    <x:String x:Key="TxtGuideHeaderDesc">增強遊戲的簡單步驟</x:String>
    <x:String x:Key="TxtGuideStep1Title">1. 找到您的遊戲</x:String>
    <x:String x:Key="TxtGuideStep1Desc">點擊「掃描遊戲」按鈕，讓應用程式自動尋找從Steam、Epic、GOG或Xbox安裝的遊戲。如果您有獨立遊戲，請勾選「手動新增」按鈕。</x:String>
    <x:String x:Key="TxtGuideStep2Title">2. 管理遊戲</x:String>
    <x:String x:Key="TxtGuideStep2Desc">在清單中您的遊戲旁邊，點擊「管理」。將開啟一個視窗，允許您為該特定遊戲安裝或更新OptiScaler模組。</x:String>
    <x:String x:Key="TxtGuideStep3Title">3. 安裝OptiScaler</x:String>
    <x:String x:Key="TxtGuideStep3Desc">在管理視窗內，選擇您的OptiScaler版本和選項。使用「自動安裝」進行快速設定。如果自動安裝失敗或無法找到正確的可執行檔（.exe），請使用「手動安裝」自己選擇遊戲的可執行檔。</x:String>
    <x:String x:Key="TxtGuideStep4Title">4. 玩遊戲</x:String>
    <x:String x:Key="TxtGuideStep4Desc">安裝後，正常啟動您的遊戲。在遊戲內，使用「Insert」鍵開啟OptiScaler選單來調整您的設定！</x:String>

    <!-- MainWindow -->
    <x:String x:Key="TxtAppTitle">Optiscaler Client Next</x:String>
    <x:String x:Key="TxtBtnScan">⟳  掃描遊戲</x:String>
    <x:String x:Key="TxtBtnAddManual">＋  手動新增</x:String>
    <x:String x:Key="TxtTipSettings">設定</x:String>
    <x:String x:Key="TxtTipComponent">元件版本</x:String>
    <x:String x:Key="TxtUpdateNukem">↑  更新NukemFG</x:String>
    <x:String x:Key="TxtTipUpdateNukem">新的NukemFG版本可用。點擊提供更新的DLL。</x:String>
    <x:String x:Key="TxtDefaultGpu">偵測GPU中…</x:String>
    <x:String x:Key="TxtManageGame">管理</x:String>
    <x:String x:Key="TxtQuickInstall">✦ 快速安裝</x:String>
    <x:String x:Key="TxtQuickUninstall">🗑️ 快速解除安裝</x:String>
    <x:String x:Key="TxtInitialScanTitle">首次掃描</x:String>
    <x:String x:Key="TxtInitialScanDesc">在掃描磁碟尋找遊戲之前，請選擇要掃描的磁碟機與來源。你可以關閉此視窗，稍後再掃描。</x:String>
    <x:String x:Key="TxtScanSetupTitle">掃描設定</x:String>
    <x:String x:Key="TxtScanSetupDesc">選擇要掃描的磁碟機與來源。你可以關閉此視窗，稍後再掃描。</x:String>
