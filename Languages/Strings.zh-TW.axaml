    <!-- ManageCacheWindow -->
    <x:String x:Key="TxtManageCacheTitle">管理本機版本</x:String>
    <x:String x:Key="TxtLocalVersions">本機版本</x:String>
    <x:String x:Key="TxtManageCacheDesc">管理已下載的OptiScaler快取</x:String>
    <x:String x:Key="TxtDownloadedVersions">已下載的OptiScaler版本：</x:String>
    <x:String x:Key="TxtDeleteIcon">🗑️ 刪除</x:String>
    <x:String x:Key="TxtNoVersions">目前沒有下載的版本。</x:String>
