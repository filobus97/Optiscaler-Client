    <x:String x:Key="TxtNoUpscalersFoundTitle">未偵測到遊戲</x:String>
    <x:String x:Key="TxtNoUpscalersFoundHint">請確認已安裝遊戲，然後按掃描重新搜尋。您也可以在掃描來源中新增自訂資料夾。</x:String>


    <!-- SteamGridDB -->
    <x:String x:Key="TxtSteamGridGuideStep1Title">1. Open the SteamGridDB API page</x:String>
    <x:String x:Key="TxtSteamGridApiKeyDesc">用於提高封面匹配的準確性。可選，但建議填寫。</x:String>
    <x:String x:Key="TxtSteamGridGuideStep2Title">2. 生成您的 API 金鑰</x:String>
    <x:String x:Key="TxtSteamGridGuideStep1Desc">前往 https://www.steamgriddb.com/profile/preferences/api 並登入。</x:String>
    <x:String x:Key="TxtSteamGridGuideStep4Desc">儲存金鑰後執行新的掃描，以便更精確地重新整理封面。</x:String>
    <x:String x:Key="TxtSteamGridGetApiKey">取得 API 金鑰</x:String>
    <x:String x:Key="TxtSteamGridGuideStep2Desc">在該頁面建立新的 API 金鑰並複製。</x:String>
    <x:String x:Key="TxtSteamGridGuideOpenPage">開啟頁面</x:String>
    <x:String x:Key="TxtSteamGridGuideStep4Title">4. 重新掃描您的遊戲</x:String>
    <x:String x:Key="TxtSteamGridGuideHeader">Get your SteamGridDB API Key</x:String>
    <x:String x:Key="TxtSteamGridGuideTitle">SteamGridDB API Key</x:String>
    <x:String x:Key="TxtSteamGridGuideHeaderDesc">快速指南以提高遊戲封面檢測的準確性。</x:String>
    <x:String x:Key="TxtSteamGridApiKey">SteamGridDB API Key</x:String>
    <x:String x:Key="TxtSteamGridApiKeyPlaceholder">Paste your SteamGridDB API key here</x:String>
    <x:String x:Key="TxtSteamGridGuideStep3Title">3. 將其貼到設定中</x:String>
    <x:String x:Key="TxtSteamGridGuideStep3Desc">Return to the app and paste the key into the SteamGridDB API Key field.</x:String>

    <x:String x:Key="TxtSteamGridGuideStep1Prefix">前往 </x:String>
    <x:String x:Key="TxtSteamGridGuideStep1Suffix"> 並登入。</x:String>

