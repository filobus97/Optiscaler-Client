    <x:String x:Key="TxtEditorEditTitleFmt">編輯: {0}</x:String>
    <x:String x:Key="TxtEditorNameLabel">配置檔名稱</x:String>
    <x:String x:Key="TxtEditorNameWatermark">輸入配置檔名稱</x:String>
    <x:String x:Key="TxtEditorDescLabel">描述</x:String>
    <x:String x:Key="TxtEditorDescWatermark">輸入描述（選填）</x:String>
    <x:String x:Key="TxtEditorModeLabel">模式</x:String>
    <x:String x:Key="TxtEditorModeEasy">簡易</x:String>
    <x:String x:Key="TxtEditorModeAdvanced">進階</x:String>
    <x:String x:Key="TxtEditorNavLabel">導覽</x:String>
    <x:String x:Key="TxtEditorSearchWm">搜尋設定...</x:String>
    <x:String x:Key="TxtEditorFooterNote">僅已設定的項目會覆蓋 OptiScaler 的預設值</x:String>
    <x:String x:Key="TxtEditorCancel">取消</x:String>
    <x:String x:Key="TxtEditorSave">儲存配置檔</x:String>

    <!-- Games View - Scan & Organize -->
    <x:String x:Key="TxtSkipNoDllsTitle">跳過無升級DLL的遊戲</x:String>
    <x:String x:Key="TxtSkipNoDllsDesc">忽略未偵測到DLSS、FSR或XeSS程式庫的遊戲。僅會新增與OptiScaler相容的遊戲。</x:String>
    <x:String x:Key="TxtRefreshCoversTitle">僅重新整理缺失封面</x:String>
    <x:String x:Key="TxtRefreshCoversDesc">跳過完整掃描，僅重試之前無法取得封面的遊戲。在設定 SteamGridDB API 金鑰後非常有用。</x:String>
    <x:String x:Key="TxtOrganizeGamesTooltip">整理遊戲</x:String>
    <x:String x:Key="TxtOrganizeModeBanner">整理模式</x:String>
    <x:String x:Key="TxtOrganizeModeReorder">▲▼ 重新排序</x:String>
    <x:String x:Key="TxtOrganizeModeHideShow">顯示/隱藏</x:String>
    <x:String x:Key="TxtOrganizeModeDone">完成</x:String>
    <x:String x:Key="TxtDragToReorder">拖曳以重新排序</x:String>
    <x:String x:Key="TxtMoveUp">上移</x:String>
    <x:String x:Key="TxtMoveDown">下移</x:String>
    <x:String x:Key="TxtHideShowGame">顯示/隱藏遊戲</x:String>
    <x:String x:Key="TxtHideGame">隱藏</x:String>
    <x:String x:Key="TxtShowGame">顯示</x:String>
    <x:String x:Key="TxtRefreshingCovers">正在重新整理缺失封面...</x:String>
    <x:String x:Key="TxtCoverRefreshDoneFmt">封面重新整理完成。找到 {0}/{1} 個缺失封面。</x:String>
    <x:String x:Key="TxtCoverRefreshToastFmt">封面重新整理完成 — 找到 {0}/{1} 個封面。</x:String>

    <!-- OptiPatcher -->
    <x:String x:Key="TxtOptiPatcherLbl">OptiPatcher</x:String>
    <x:String x:Key="TxtOptiPatcherTooltip">OptiScaler 的 ASI 插件，在受支援的遊戲中無需欺騙即可公開 DLSS/DLSS-FG 輸入。幫助 Intel Arc 使用者避免 D3D12 錯誤，並防止 Dxgi 欺騙導致的效能負擔或崩潰。</x:String>
    <x:String x:Key="TxtDownloadingOptiPatcher">正在下載 OptiPatcher...</x:String>
    <x:String x:Key="TxtInstallingOptiPatcher">正在安裝 OptiPatcher...</x:String>
    <x:String x:Key="TxtVersionMgmtInfoTitle">版本管理</x:String>
    <x:String x:Key="TxtVersionMgmtInfoDesc">OptiScaler、OptiPatcher、FSR4 INT8、Fakenvapi 和 NukemFG 的版本可以在設定中的本機快取與預設版本管理區塊進行管理。</x:String>
    <x:String x:Key="TxtSetDefault">設為預設</x:String>
    <x:String x:Key="TxtClearDefault">清除</x:String>
    <x:String x:Key="TxtDefaultBadge">預設</x:String>
    <x:String x:Key="TxtCurrentDefaultFormat">目前預設: {0}</x:String>
    <x:String x:Key="TxtNoDefaultSet">未設定預設版本</x:String>
    <!-- Network / Proxy Settings -->
    <x:String x:Key="TxtNetworkTitle">網路與 Proxy</x:String>
    <x:String x:Key="TxtNetworkDesc">為 GitHub API 與下載連線配置 HTTP(S) 代理。</x:String>
    <x:String x:Key="TxtNetworkWindowDesc">為 GitHub API 與下載連線配置 HTTP(S) 或 SOCKS5 代理。留空以使用系統代理。</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxy">使用系統代理</x:String>
    <x:String x:Key="TxtNetworkUseSystemProxyDesc">啟用時，使用作業系統的代理設定與 HTTP_PROXY / HTTPS_PROXY 環境變數。欲設定自訂代理請停用此項。</x:String>
    <x:String x:Key="TxtNetworkProxyConfig">代理設定</x:String>
    <x:String x:Key="TxtNetworkProxyType">類型</x:String>
    <x:String x:Key="TxtNetworkProxyHost">主機</x:String>
    <x:String x:Key="TxtNetworkProxyHostPlaceholder">proxy.example.com</x:String>
    <x:String x:Key="TxtNetworkProxyPort">連接埠</x:String>
    <x:String x:Key="TxtNetworkProxyPortPlaceholder">3128</x:String>
    <x:String x:Key="TxtNetworkRequiresAuth">代理需要驗證</x:String>
    <x:String x:Key="TxtNetworkCredentials">憑證</x:String>
    <x:String x:Key="TxtNetworkUsername">使用者名稱</x:String>
    <x:String x:Key="TxtNetworkUsernamePlaceholder">選填</x:String>
    <x:String x:Key="TxtNetworkPassword">密碼</x:String>
    <x:String x:Key="TxtNetworkPasswordPlaceholder">選填</x:String>
    <x:String x:Key="TxtNetworkTestBtn">測試連線</x:String>
    <x:String x:Key="TxtNetworkTestOk">✓ 已連線</x:String>
    <x:String x:Key="TxtNetworkTestFail">✗ 失敗</x:String>
    <x:String x:Key="TxtNetworkTestTesting">測試中…</x:String>

    <!-- Welcome popup -->
    <x:String x:Key="TxtWelcomeChangelogTitle">更新日誌</x:String>
    <x:String x:Key="TxtWelcomeChangelogContent">此版本的完整變更和新功能列表可在 GitHub 上查看。</x:String>
    <x:String x:Key="TxtWelcomeChangelogLink">&#x2197; 在 GitHub 上查看更新日誌</x:String>
    <x:String x:Key="TxtWelcomeGuideTitle">快速入門</x:String>
    <x:String x:Key="TxtWelcomeGuideContent">強烈建議查看說明選項卡中的內建指南，以便熟悉應用程式或解答特定問題。</x:String>
</ResourceDictionary>



