<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OptiscalerClient.Views.ImportFsr4DllDialog"
        Title="Import Custom FSR 4 DLL"
        Width="600"
        Height="560"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False">

    <Panel Margin="16" Name="RootPanel" Opacity="0">
        <Border CornerRadius="12"
                Background="{StaticResource BrBgBase}"
                BoxShadow="0 10 30 0 #A0000000">

            <Grid>
                <Border CornerRadius="12"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="1"
                        ZIndex="10"
                        IsHitTestVisible="False"/>

                <Border CornerRadius="12"
                        Background="Transparent"
                        ClipToBounds="True">

                    <Grid RowDefinitions="Auto, *, Auto">

                        <!-- Title bar -->
                        <Border Grid.Row="0"
                                Name="TitleBar"
                                Background="{StaticResource BrBgDeep}"
                                Padding="24,18"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Import Custom FSR 4 DLL"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                    <TextBlock Text="FSR 4.x INT8 (amdxcffx64.dll)"
                                               FontSize="12"
                                               Foreground="{StaticResource BrAccent}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="✕"
                                        Classes="BtnSecondary"
                                        Padding="8,4"
                                        MinWidth="32"
                                        FontSize="14"
                                        Click="BtnCancel_Click"
                                        VerticalAlignment="Top"
                                        Background="Transparent"
                                        BorderThickness="0"/>
                            </Grid>
                        </Border>

                        <!-- Content -->
                        <ScrollViewer Grid.Row="1" Margin="0" Padding="0">
                            <StackPanel Spacing="14" Margin="24,18">

                                <!-- Legal / sourcing notice -->
                                <Border Background="#1AFF9800"
                                        BorderBrush="#FF9800"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12,10">
                                    <TextBlock Text="This tool does not provide the DLL. You must supply a file you obtained yourself. amdxcffx64.dll is proprietary AMD software and is never downloaded, bundled, or linked by this application."
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="#FF9800"/>
                                </Border>

                                <TextBlock Text="Select the amdxcffx64.dll you want to use. OptiScaler loads this DLL from the game folder to enable newer FSR 4 models (e.g. the 4.1.x INT8 model) on pre-RDNA4 GPUs."
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="{StaticResource BrTextPrimary}"
                                           LineHeight="20"/>

                                <!-- File picker -->
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBox Name="TxtSelectedPath"
                                             Grid.Column="0"
                                             IsReadOnly="True"
                                             Watermark="No file selected..."
                                             Margin="0,0,10,0"
                                             FontSize="12"/>
                                    <Button Name="BtnBrowse"
                                            Grid.Column="1"
                                            Content="Browse..."
                                            Classes="BtnSecondary"
                                            Click="BtnBrowse_Click"/>
                                </Grid>

                                <!-- Rename warning (filename != amdxcffx64.dll) -->
                                <Border Name="PnlRenameWarning"
                                        Background="#1AFFC107"
                                        BorderBrush="#FFC107"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        IsVisible="False">
                                    <TextBlock Name="TxtRenameWarning"
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Foreground="#FFC107"/>
                                </Border>

                                <!-- DLL info card -->
                                <Border Name="PnlDllInfo"
                                        Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16,12"
                                        IsVisible="False">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Detected DLL information"
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="{StaticResource BrTextPrimary}"/>
                                        <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="File version:" FontSize="12" Foreground="{StaticResource BrTextSecondary}"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Name="TxtFileVersion" FontSize="12" FontFamily="Consolas, Monospace" Foreground="{StaticResource BrAccentWarm}"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Product version:" FontSize="12" Foreground="{StaticResource BrTextSecondary}"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Name="TxtProductVersion" FontSize="12" FontFamily="Consolas, Monospace" Foreground="{StaticResource BrTextPrimary}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Signature:" FontSize="12" Foreground="{StaticResource BrTextSecondary}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Name="TxtSignature" FontSize="12" Foreground="{StaticResource BrTextPrimary}"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="SHA-256:" FontSize="12" Foreground="{StaticResource BrTextSecondary}"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Name="TxtSha256" FontSize="10" FontFamily="Consolas, Monospace" TextWrapping="Wrap" Foreground="{StaticResource BrTextSecondary}"/>
                                        </Grid>
                                        <TextBlock Name="TxtModelHint"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Validation error -->
                                <Border Name="PnlError"
                                        Background="#1AF44336"
                                        BorderBrush="#F44336"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        IsVisible="False">
                                    <TextBlock Name="TxtError"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="#F44336"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer -->
                        <Border Grid.Row="2"
                                Padding="24,18"
                                Background="{StaticResource BrBgDeep}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="0,1,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                <Button Name="BtnCancel"
                                        Content="Cancel"
                                        Classes="BtnSecondary"
                                        Click="BtnCancel_Click"/>
                                <Button Name="BtnImport"
                                        Content="Import"
                                        Classes="BtnPrimary"
                                        IsEnabled="False"
                                        Click="BtnImport_Click"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Dim backdrop shown behind child dialogs -->
        <Border Name="DimOverlay"
                CornerRadius="12"
                Background="#A0000000"
                IsVisible="False"
                ZIndex="9999"/>
    </Panel>
</Window>
